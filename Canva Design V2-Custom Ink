      cornerSize: 30
  });

  fabric.Object.prototype.controls.br = new fabric.Control({
      x: 0.5, y: 0.5, cursorStyle: 'nwse-resize',
      actionHandler: fabric.controlsUtils.scalingEqually,
      actionName: 'scale',
      render: function(ctx, left, top, styleOverride, fabricObject) {

  var canvas = new fabric.Canvas('design-canvas', {
    width: CANVAS_W,
    height: CANVAS_H,
    selection: true,
    preserveObjectStacking: true
  });

  /* ─── NEW MERGED: CENTER SNAPPING LOGIC ─────────────────────────────── */
  canvas.on('object:moving', function(options) { 
    // Only snap to center for banner mode as requested, grid/shapes removed
    if(!isBannerMode) return;
    
    var obj = options.target;
    const snapDist = 15;
    const centerX = window.baseVisualWidth / 2;
    const centerY = window.baseVisualHeight / 2;
    if (Math.abs(obj.left - centerX) < snapDist) obj.set({ left: centerX });
    if (Math.abs(obj.top - centerY) < snapDist) obj.set({ top: centerY });
  });

  /* ─── Advanced ApparelText Class (Gradient Support Added) ──────────────── */
  fabric.ApparelText = fabric.util.createClass(fabric.Object, {
    type: 'apparelText',
    stateProperties: fabric.Object.prototype.stateProperties.concat([
      'text', 'effect', 'intensity', 'spacing', 'fontFamily', 'fontSize', 'fill', 'fontWeight', 'fontStyle', 'textAlign', 'stroke', 'strokeWidth', 'shadow'
    ]),

    initialize: function(text, options) {
      options = options || {};
      this.text      = text || 'Your Text';
      this.effect    = options.effect || 'normal';
      this.intensity = options.intensity !== undefined ? options.intensity : 120;
      this.spacing   = options.spacing || 0;
      this.fontFamily = options.fontFamily || 'Arial';
      this.fontSize  = options.fontSize || 45;
      this.fontWeight = options.fontWeight || 'bold';
      this.fontStyle  = options.fontStyle || 'normal';
      this.fill      = options.fill || '#121212';
      this.stroke    = options.stroke || null;
      this.strokeWidth = options.strokeWidth || 0;
      this.shadow    = options.shadow || null;
      this.callSuper('initialize', options);
      this._calcBounds();
    },

    _getFontString: function() {
      return (this.fontStyle || 'normal') + ' ' + (this.fontWeight || 'normal') + ' ' + this.fontSize + 'px ' + this.fontFamily;
    },

    _measureChars: function(ctx) {
       ctx.font = this._getFontString();
       var chars = this.text ? this.text.split('') : [];
       var widths = chars.map(function(c) { return ctx.measureText(c).width; });
       return { chars: chars, widths: widths };
    },

    _calcBounds: function() {
       var c = document.createElement('canvas').getContext('2d');
       var m = this._measureChars(c);
       var tw = 0;
       m.widths.forEach(w => tw += w + this.spacing);
       tw = Math.max(1, tw - this.spacing);

       var strokePad = this.strokeWidth || 0;

       if (this.effect === 'curve' || this.effect === 'arch') {
           var radius = 2000 / Math.max(1, (this.intensity / 10));
           if (this.effect === 'curve') radius = -radius; 
           
           var absRadius = Math.abs(radius);
           var totalAngle = tw / absRadius;
           var halfAngle = totalAngle / 2;
           var top = -absRadius - this.fontSize;
           var bottom = Math.sin(halfAngle) * absRadius + this.fontSize;
           var left = -Math.cos(halfAngle) * absRadius - this.fontSize;
           var right = Math.cos(halfAngle) * absRadius + this.fontSize;
           this.set({ width: Math.abs(left)+Math.abs(right) + strokePad, height: Math.abs(top)+Math.abs(bottom) + strokePad });
           this._curveRadius = radius;
       } else {
           var maxScaleY = 1;
           var maxOffsetY = 0;
           var amt = this.intensity / 150;
           
           if (this.effect === 'bulge' || this.effect === 'perspective') maxScaleY = 1 + amt;
           if (this.effect === 'bridge' || this.effect === 'valley' || this.effect === 'pointed' || this.effect === 'upward' || this.effect === 'downward') {
               maxOffsetY = (amt * this.fontSize);
           }
           
           this.set({ 
               width: tw + strokePad, 
               height: (this.fontSize * maxScaleY) + Math.abs(maxOffsetY) + strokePad 
           });
       }
    },

    _render: function(ctx) {
       if (!this.text) return;
       ctx.font = this._getFontString();
       ctx.textAlign = 'center';
       ctx.textBaseline = 'middle';
       
       var chars = this.text.split('');
       var charWidths = chars.map(c => ctx.measureText(c).width);
       var tw = charWidths.reduce((a,b) => a + b + this.spacing, 0) - this.spacing;

       if (this.shadow) {
           ctx.shadowColor = this.shadow.color;
           ctx.shadowBlur = this.shadow.blur;
           ctx.shadowOffsetX = this.shadow.offsetX;
           ctx.shadowOffsetY = this.shadow.offsetY;
       } else {
           ctx.shadowColor = 'transparent';
       }

       // Parse Gradient for custom drawing if applied
       var fillValue = this.fill;
       if (fillValue && fillValue.toLive) fillValue = fillValue.toLive(ctx, this);

       if (this.effect === 'curve' || this.effect === 'arch') {
           var r = Math.abs(this._curveRadius || 200);
           var isReverse = (this._curveRadius < 0);
           var totalAngle = tw / r;
           var startAngle = isReverse ? (Math.PI/2 + totalAngle/2) : (-Math.PI/2 - totalAngle/2);
           var curAngle = startAngle;

           for (var i=0; i<chars.length; i++) {
               var cAngle = charWidths[i]/r;
               var mAngle = isReverse ? (curAngle - cAngle/2) : (curAngle + cAngle/2);
               ctx.save();
               ctx.translate(Math.cos(mAngle)*r, Math.sin(mAngle)*r);
               ctx.rotate(isReverse ? mAngle - Math.PI/2 : mAngle + Math.PI/2);
               if (this.stroke && this.stroke !== 'transparent') {
                   ctx.strokeStyle = this.stroke; ctx.lineWidth = this.strokeWidth;
                   ctx.lineJoin = 'round'; ctx.strokeText(chars[i], 0, 0);
               }
               ctx.fillStyle = fillValue; ctx.fillText(chars[i], 0, 0);
               ctx.restore();
               curAngle = isReverse ? (curAngle - cAngle - this.spacing/r) : (curAngle + cAngle + this.spacing/r);
           }
       } else {
           var len = chars.length;
           var center = (len - 1) / 2;
           var amt = this.intensity / 150; 
           
           ctx.save();
           ctx.translate(-tw/2, 0); 
           var curX = 0;
           for (var i=0; i<len; i++) {
               var norm = len > 1 ? (i / (len - 1)) : 0; 
               var dist = len > 1 ? Math.abs(i - center) / center : 0; 
               var scaleY = 1, scaleX = 1, offsetY = 0;

               switch(this.effect) {
                   case 'pinch': scaleY = 1 - ((1 - dist) * (amt * 0.4)); break;
                   case 'bulge': scaleY = 1 + ((1 - dist) * (amt * 0.6)); break;
                   case 'bridge': offsetY = -Math.sin(norm * Math.PI) * (amt * this.fontSize * 0.8); break;
                   case 'valley': offsetY = Math.sin(norm * Math.PI) * (amt * this.fontSize * 0.8); break;
                   case 'pointed': offsetY = -(1 - dist) * (amt * this.fontSize * 0.8); break;
                   case 'cone': scaleY = 1 - (norm * amt * 0.5); break;
                   case 'upward': offsetY = -norm * (amt * this.fontSize); break;
                   case 'downward': offsetY = norm * (amt * this.fontSize); break;
                   case 'perspective': scaleY = 1 + (norm * amt); scaleX = 1 + (norm * amt * 0.2); break;
               }

               ctx.save();
               ctx.translate(curX + charWidths[i]/2, offsetY);
               ctx.scale(scaleX, scaleY);
               
               if (this.stroke && this.stroke !== 'transparent') {
                   ctx.strokeStyle = this.stroke; ctx.lineWidth = this.strokeWidth;
                   ctx.lineJoin = 'round'; ctx.strokeText(chars[i], 0, 0);
               }
               ctx.fillStyle = fillValue; ctx.fillText(chars[i], 0, 0);
               ctx.restore();

               curX += charWidths[i] + this.spacing;
           }
           ctx.restore();
       }
    }
  });


  /* ─── NEW MERGED: Apply Gradient Feature ────────────────────────────── */
  function applyGradient() {
      var c1 = document.getElementById('grad-color-1').value;
      var c2 = document.getElementById('grad-color-2').value;
      var dir = document.getElementById('grad-dir').value;

      var gradientOpts = {
          type: 'linear',
          colorStops: [ { offset: 0, color: c1 }, { offset: 1, color: c2 } ]
      };

      if (colorTargetType === 'fill') {
          var obj = getActiveDesignObj();
          if(obj) {
              var w = obj.width;
              var h = obj.height;
              // Set relative coordinates based on the selected direction
              var coords = { x1: -w/2, y1: 0, x2: w/2, y2: 0 }; // Horizontal
              if(dir === 'vertical') coords = { x1: 0, y1: -h/2, x2: 0, y2: h/2 };
              if(dir === 'diagonal') coords = { x1: -w/2, y1: -h/2, x2: w/2, y2: h/2 };
              gradientOpts.coords = coords;

              var grad = new fabric.Gradient(gradientOpts);
              obj.set('fill', grad);
              canvas.renderAll();
              saveHistory();

              // Update the visual thumbnail
              let gradBg = (dir==='vertical') ? 'linear-gradient(to bottom, '+c1+', '+c2+')' : 
                           (dir==='diagonal') ? 'linear-gradient(135deg, '+c1+', '+c2+')' : 
                           'linear-gradient(to right, '+c1+', '+c2+')';
              document.getElementById('preview-fill-color').classList.remove('checkerboard-pattern');
              document.getElementById('preview-fill-color').style.background = gradBg;
          } else {
              showToast("Select a text object first.", "error");
          }
      } else if (colorTargetType === 'canvasBg') {
          var cw = canvas.width;
          var ch = canvas.height;
          var coords = { x1: 0, y1: 0, x2: cw, y2: 0 }; // Horizontal
          if(dir === 'vertical') coords = { x1: 0, y1: 0, x2: 0, y2: ch };
          if(dir === 'diagonal') coords = { x1: 0, y1: 0, x2: cw, y2: ch };
          gradientOpts.coords = coords;

          var grad = new fabric.Gradient(gradientOpts);
          canvas.backgroundColor = grad;
          canvas.renderAll();
          saveHistory();

          let gradBg = (dir==='vertical') ? 'linear-gradient(to bottom, '+c1+', '+c2+')' : 
                       (dir==='diagonal') ? 'linear-gradient(135deg, '+c1+', '+c2+')' : 
                       'linear-gradient(to right, '+c1+', '+c2+')';
          document.getElementById('preview-canvas-bg').classList.remove('checkerboard-pattern');
          document.getElementById('preview-canvas-bg').style.background = gradBg;
      } else {
          showToast('Gradients are only supported for Text and Canvas Background.', 'error');
          return;
      }

      closeColorModal();
  }
  window.applyGradient = applyGradient;


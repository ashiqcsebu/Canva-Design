  function handleImageUpload(file) {
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { showToast('Max 5MB allowed.', 'error'); return; }
    var reader = new FileReader();
    reader.onload = function(e) {
      fabric.Image.fromURL(e.target.result, function(img) {
        if (!img) return;
        var scale = Math.min((window.baseVisualWidth * 0.7) / img.width, (window.baseVisualHeight * 0.7) / img.height, 1);
        img.set({ left: window.baseVisualWidth / 2, top: window.baseVisualHeight / 2, originX: 'center', originY: 'center', scaleX: scale, scaleY: scale });
        img.filters = [];
        canvas.add(img);
        canvas.setActiveObject(img);
        canvas.renderAll();
        saveHistory();
      });
    };
    reader.readAsDataURL(file);
  }
  window.handleImageUpload = handleImageUpload;


  var rotateImg = document.createElement('img');
  rotateImg.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='white'%3E%3Ccircle cx='12' cy='12' r='11' stroke='none'/%3E%3Cpath d='M19 11A7.5 7.5 0 0 0 5 9M4.5 9h4M4.5 9V4.5' stroke='%232563eb' stroke-width='2' stroke-linecap='round' fill='none'/%3E%3C/svg%3E";

  var scaleImg = document.createElement('img');
  scaleImg.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='white'%3E%3Ccircle cx='12' cy='12' r='11' stroke='none'/%3E%3Cpath d='M16 8l-4 4m4-4v4m0-4h-4M8 16l4-4m-4 4v-4m0 4h4' stroke='%232563eb' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' fill='none'/%3E%3C/svg%3E";

  function renderCustomIcon(ctx, left, top, styleOverride, fabricObject, iconObj) {
      var size = this.cornerSize;
      ctx.save();
      ctx.translate(left, top);
      ctx.rotate(fabric.util.degreesToRadians(fabricObject.angle));
      ctx.drawImage(iconObj, -size/2, -size/2, size, size);

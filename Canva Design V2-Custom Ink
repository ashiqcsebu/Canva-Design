  /* ─── OFF-SCREEN RENDERER FOR CART ───────────────────── */
  function generateOffscreenImages(json, bgUrl, callback) {
    var tempCanvas = new fabric.StaticCanvas(null, { width: window.baseVisualWidth, height: window.baseVisualHeight });
    var doRender = function() {
      tempCanvas.backgroundImage = null;
      tempCanvas.backgroundColor = null;
      tempCanvas.renderAll();
      var transparentDataUrl = tempCanvas.toDataURL({ format: 'png', multiplier: 1.5 });

      if (bgUrl && bgUrl.indexOf('no-image') === -1) {
        var finalUrl = bgUrl;
        if(bgUrl.indexOf('//') === 0) finalUrl = 'https:' + bgUrl;
        
        fabric.Image.fromURL(finalUrl, function(img) {
          if (img) {
            var scaleFactor = Math.min(window.baseVisualWidth / img.width, window.baseVisualHeight / img.height);
            tempCanvas.setBackgroundImage(img, function() {
              tempCanvas.renderAll();
              var bgDataUrl = tempCanvas.toDataURL({ format: 'png', multiplier: 1.5 });
              callback({ transparent: transparentDataUrl, withBg: bgDataUrl });
            }, { originX: 'center', originY: 'center', left: window.baseVisualWidth/2, top: window.baseVisualHeight/2, crossOrigin: 'anonymous' });
          } else { callback({ transparent: transparentDataUrl, withBg: transparentDataUrl }); }
        }, { crossOrigin: 'anonymous' });
      } else { callback({ transparent: transparentDataUrl, withBg: transparentDataUrl }); }
    };

    if (json) { tempCanvas.loadFromJSON(json, function() { doRender(); }); } 
    else { doRender(); }
  }

  /* ─── EXPORT BUTTONS ────────────────────────────────────── */
  function exportDesign(format) {
      canvas.setZoom(1);
      canvas.setWidth(window.baseVisualWidth);
      canvas.setHeight(window.baseVisualHeight);

      var dataUrl = canvas.toDataURL({ format: format === 'jpg' ? 'jpeg' : 'png', quality: 1, multiplier: 3 });
      var link = document.createElement('a');
      link.download = 'MyDesign.' + format;
      link.href = dataUrl;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);

      applyZoomAndSize();
  }
  window.exportDesign = exportDesign;

  /* ─── DYNAMIC Cart submit ────────────────────────────────────── */
  function dataURLtoFile(dataurl, filename) {
    var arr   = dataurl.split(',');
    var mimeMatch = arr[0].match(/:(.*?);/);
    var mime  = mimeMatch ? mimeMatch[1] : 'image/png';
    var bstr  = atob(arr[arr.length - 1]);
    var n     = bstr.length;
    var u8arr = new Uint8Array(n);
    while (n--) { u8arr[n] = bstr.charCodeAt(n); }
    return new File([u8arr], filename, { type: mime });
  }

  function handleCartSubmit(e) {
    if (e && typeof e.preventDefault === 'function') e.preventDefault();
    if (window.isSubmitting) return;
    
    var btn = document.getElementById('add-to-cart-submit-bottom');
    if(btn) { btn.innerHTML = 'Processing...'; btn.disabled  = true; }
    window.isSubmitting = true;

    saveAreaState();

    if(isBannerMode) {
        showToast('To add to cart, please switch back to Apparel mode.', 'error');
        if(btn) { btn.innerHTML = 'Add to Cart <i class="fa-solid fa-cart-shopping"></i>'; btn.disabled  = false; }
        window.isSubmitting = false;
        return;
    }

    var renderPromises = availableViews.map(function(view) {
        var state = areaStates[view] ? areaStates[view].json : null;
        var viewBgUrl = getImageUrlForVariantAndView(currentColorName, view) || fallbackImage;

        return generateOffscreenImageAsync(state, viewBgUrl).then(function(dataUrls) {
            var capView = view.charAt(0).toUpperCase() + view.slice(1);
            return { 
                view: capView, 
                fileBg: dataURLtoFile(dataUrls.withBg, capView + '-Preview.png'),
                fileTransparent: dataURLtoFile(dataUrls.transparent, capView + '-Design.png')
            };
        });
    });

    Promise.all(renderPromises).then(function(renderedViews) {
        var qty           = parseInt(document.getElementById('quantity').value, 10) || 1;
        var bundleId      = 'bundle-' + Date.now();
        var mainVariantId = document.getElementById('selected-variant-id').value;

        var selectedAddons = [];
        document.querySelectorAll('.addon-checkbox:checked').forEach(function(cb) {
          selectedAddons.push({
            vid:   cb.getAttribute('data-vid'),
            label: cb.getAttribute('data-label'),
            price: parseInt(cb.getAttribute('data-price') || '0', 10)
          });
        });

        var mainFormData = new FormData();
        mainFormData.append('id', mainVariantId);
        mainFormData.append('quantity', qty);
        mainFormData.append('properties[_bundle_id]',      bundleId);
        
        renderedViews.forEach(function(res) {
            mainFormData.append('properties[' + res.view + ' Preview]', res.fileBg);
            mainFormData.append('properties[' + res.view + ' Design (Transparent)]', res.fileTransparent);
        });
        
        selectedAddons.forEach(function(addon) {
          mainFormData.append('properties[' + addon.label + ']', formatMoney(addon.price));
        });

        document.querySelectorAll('.custom-metafield-input').forEach(function(input) {
          if (input.value.trim() !== '') {
            mainFormData.append('properties[' + input.getAttribute('data-label') + ']', input.value.trim());
          }
        });

        var cartDrawerEl = document.querySelector('cart-drawer');
        var rootPath = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';

        if (selectedAddons.length === 0) {
          mainFormData.append('sections', cartDrawerEl ? 'cart-drawer,cart-icon-bubble' : 'cart-icon-bubble');
          mainFormData.append('sections_url', window.location.pathname);
        }

        fetch(rootPath + 'cart/add.js', {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
          body: mainFormData
        })
        .then(function(response) {
          if (!response.ok) return response.text().then(function(text) { throw new Error('Failed to add main item: ' + text); });
          return response.json();
        })
        .then(function(mainData) {
          if (selectedAddons.length > 0) {
            var addonsPayload = {
              items: selectedAddons.map(function(addon) {
                return {
                  id: addon.vid, quantity: qty,
                  properties: { _bundle_id: bundleId, _hidden_addon: 'true', _parent_variant: mainVariantId }
                };
              })
            };

            if (cartDrawerEl) {
              addonsPayload.sections = 'cart-drawer,cart-icon-bubble';
              addonsPayload.sections_url = window.location.pathname;
            }

            return fetch(rootPath + 'cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify(addonsPayload)
            })
            .then(function(res) {
              if (!res.ok) throw new Error('Failed to add customizations');
              return res.json();
            });
          } else { return mainData; }
        })
        .then(function(finalData) {
          if (cartDrawerEl) {
            if (typeof cartDrawerEl.renderContents === 'function') cartDrawerEl.renderContents(finalData);
            if (typeof cartDrawerEl.open === 'function') cartDrawerEl.open();
            cartDrawerEl.classList.remove('is-empty');
          } else { window.location.href = rootPath + 'cart'; }
          showToast('Added to cart!');
        })
        .catch(function(error) {
          console.error('Cart error:', error);
          showToast('Something went wrong adding to cart.', 'error');
        })
        .finally(function() {
          if(btn) { btn.innerHTML = 'Add to Cart <i class="fa-solid fa-cart-shopping"></i>'; btn.disabled  = false; }
          window.isSubmitting = false;
        });
    });
  }
  window.handleCartSubmit = handleCartSubmit;

  /* ─── Init ───────────────────────────────────────────── */
  historyData.push(JSON.stringify(canvas.toJSON(CUSTOM_PROPS)));
  historyIdx = 0;

  initFontGrid();
  initColorGrid();
  initVariantState();
  findAndUpdateVariant();

  // Ensuring all sidebar panels are closed by default
  document.querySelectorAll('.tool-card').forEach(function(card) {
      card.classList.remove('active');
  });

})();
</script>

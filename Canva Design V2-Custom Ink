  function syncPropsToUI() {
    var obj = getActiveDesignObj();
    var imgProps = document.getElementById('image-properties-wrapper');
    var shadowControls = document.getElementById('shadow-controls');
    
    if (!obj) {
      imgProps.classList.add('hidden');
      return;
    }

    if(obj.shadow) {
        document.getElementById('prop-shadow-toggle').checked = true;
        shadowControls.classList.remove('hidden');
        document.getElementById('prop-shadow-blur').value = obj.shadow.blur;
        document.getElementById('prop-shadow-color').value = obj.shadow.color;
        document.getElementById('preview-shadow-color').style.background = obj.shadow.color;
    } else {
        document.getElementById('prop-shadow-toggle').checked = false;
        shadowControls.classList.add('hidden');
    }

    if (obj.type === 'image') {
      imgProps.classList.remove('hidden');
      document.getElementById('prop-brightness').value  = '0';
      document.getElementById('prop-grayscale').checked = false;
      if (obj.filters && obj.filters.length) {
        obj.filters.forEach(function(f) {
          if (!f) return;
          if (f.type === 'Brightness') document.getElementById('prop-brightness').value = f.brightness || 0;
          if (f.type === 'Grayscale')  document.getElementById('prop-grayscale').checked = true;
        });
      }
    } else {
      imgProps.classList.add('hidden');
    }

    if (obj.type === 'i-text' || obj.type === 'apparelText' || obj.type === 'text') {
        document.getElementById('master-text-val').value = obj.text || '';
        
        var fFamily = obj.fontFamily || 'Arial';
        document.getElementById('master-font').value = fFamily;
        document.getElementById('label-master-font').innerHTML = fFamily + ' <i class="fa-solid fa-chevron-right" style="font-size:10px; color:#ccc;"></i>';
        
        document.getElementById('master-size').value = obj.fontSize || 45;
        if(document.getElementById('val-master-size')) document.getElementById('val-master-size').innerText = obj.fontSize || 45;

        if(document.getElementById('master-rotation')) document.getElementById('master-rotation').value = Math.round(obj.angle) || 0;
        if(document.getElementById('val-master-rotation')) document.getElementById('val-master-rotation').innerText = Math.round(obj.angle) + '°';

        if (obj.fill && typeof obj.fill === 'string') {
            document.getElementById('master-color').value = obj.fill;
            if(obj.fill === 'transparent') {
                document.getElementById('preview-fill-color').style.background = '';
                document.getElementById('preview-fill-color').classList.add('checkerboard-pattern');
            } else {
                document.getElementById('preview-fill-color').classList.remove('checkerboard-pattern');
                document.getElementById('preview-fill-color').style.background = obj.fill;
            }
        } else if (obj.fill && obj.fill.colorStops) {
            // If it is a gradient
            let c1 = obj.fill.colorStops[0].color;
            let c2 = obj.fill.colorStops[obj.fill.colorStops.length-1].color;
            document.getElementById('preview-fill-color').classList.remove('checkerboard-pattern');
            document.getElementById('preview-fill-color').style.background = 'linear-gradient(to right, '+c1+', '+c2+')';

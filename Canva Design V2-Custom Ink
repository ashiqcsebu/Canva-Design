  var PRESET_COLORS = [
      '#ffffff', '#000000', '#4b5563', '#9ca3af', '#d1d5db', '#ef4444', '#f97316', '#f59e0b', '#eab308',
      '#84cc16', '#22c55e', '#10b981', '#14b8a6', '#06b6d4', '#0ea5e9', '#3b82f6', '#6366f1', '#8b5cf6',

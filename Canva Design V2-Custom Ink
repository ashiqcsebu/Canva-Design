        if (obj.stroke && typeof obj.stroke === 'string' && obj.stroke !== 'transparent') {
            document.getElementById('master-stroke-color').value = obj.stroke;
            document.getElementById('preview-stroke-color').classList.remove('checkerboard-pattern');
            document.getElementById('preview-stroke-color').style.background = obj.stroke;
            document.getElementById('preview-stroke-color').style.borderStyle = 'solid';
        } else {
            document.getElementById('master-stroke-color').value = 'transparent';
            document.getElementById('preview-stroke-color').style.background = '';
            document.getElementById('preview-stroke-color').classList.add('checkerboard-pattern');
            document.getElementById('preview-stroke-color').style.borderStyle = 'dashed';
        }

        document.getElementById('master-stroke-width').value = obj.strokeWidth || 0;
        document.getElementById('val-master-stroke-width').innerText = obj.strokeWidth || 0;

        if(obj.charSpacing !== undefined) document.getElementById('prop-char-spacing').value = obj.charSpacing;

  /* ─── NEW MERGED: Unit Conversion & Ruler Logic ──────────────────── */
  // Initial global state for physical units
  window.currentPhysWidth = 120;
  window.currentPhysHeight = 60;
  window.currentPhysUnit = 'in';

  function applyZoomAndSize() {
      canvas.setZoom(window.currentZoom);
      let finalW = window.baseVisualWidth * window.currentZoom;
      let finalH = window.baseVisualHeight * window.currentZoom;
      
      canvas.setWidth(finalW);
      canvas.setHeight(finalH);
      
      const wrapper = document.getElementById('canvas-ruler-wrapper');
      wrapper.style.width = finalW + 'px';
      wrapper.style.height = finalH + 'px';

      canvas.renderAll();

      // Redraw rulers with scaled (zoomed) dimensions automatically
      if (isBannerMode && window.currentPhysWidth) {
          drawRulers(window.currentPhysWidth, window.currentPhysHeight, window.currentPhysUnit, finalW, finalH);
      }
  }
  
  function changeZoom(amount) {
      window.currentZoom += amount;
      if(window.currentZoom < 0.5) window.currentZoom = 0.5;
      if(window.currentZoom > 3) window.currentZoom = 3;
      document.getElementById('zoom-level').innerText = Math.round(window.currentZoom * 100) + '%';
      applyZoomAndSize();
  }
  window.changeZoom = changeZoom;

  function convertValue(val, fromUnit, toUnit) {
      let inches = val;
      if(fromUnit === 'ft') inches = val * 12;
      if(fromUnit === 'm') inches = val * 39.3701;
      
      if(toUnit === 'in') return inches;
      if(toUnit === 'ft') return inches / 12;
      if(toUnit === 'm') return inches / 39.3701;
      return val;
  }

  function updateCanvasRatio() {
      let widthInput = document.getElementById('phys-width').value;
      let heightInput = document.getElementById('phys-height').value;
      if(!widthInput || !heightInput) return;

      let pW = parseFloat(widthInput);
      let pH = parseFloat(heightInput);
      let unit = document.getElementById('phys-unit').value;

      // Update globals so zoom function can use them
      window.currentPhysWidth = pW;
      window.currentPhysHeight = pH;
      window.currentPhysUnit = unit;

      let in_W = convertValue(pW, unit, 'in').toFixed(2);
      let in_H = convertValue(pH, unit, 'in').toFixed(2);
      let ft_W = convertValue(pW, unit, 'ft').toFixed(2);
      let ft_H = convertValue(pH, unit, 'ft').toFixed(2);
      let m_W = convertValue(pW, unit, 'm').toFixed(2);
      let m_H = convertValue(pH, unit, 'm').toFixed(2);

      let convHTML = `<strong>Equivalent Size:</strong><br>`;
      if(unit !== 'in') convHTML += `Inches: ${in_W} in × ${in_H} in<br>`;
      if(unit !== 'ft') convHTML += `Feet: ${ft_W} ft × ${ft_H} ft<br>`;
      if(unit !== 'm') convHTML += `Meters: ${m_W} m × ${m_H} m`;
      
      document.getElementById('conversion-display').innerHTML = convHTML;

      const MAX_VISUAL_WIDTH = 800;
      const MAX_VISUAL_HEIGHT = 500;
      const aspect_ratio = pW / pH;

      let newVisualW = MAX_VISUAL_WIDTH;
      let newVisualH = MAX_VISUAL_WIDTH / aspect_ratio;

      if (newVisualH > MAX_VISUAL_HEIGHT) {
          newVisualH = MAX_VISUAL_HEIGHT;
          newVisualW = MAX_VISUAL_HEIGHT * aspect_ratio;
      }

      window.baseVisualWidth = newVisualW;
      window.baseVisualHeight = newVisualH;

      applyZoomAndSize(); // This will naturally calculate scale and redraw rulers
  }
  window.updateCanvasRatio = updateCanvasRatio;

  function drawRulers(pW, pH, unit, vW, vH) {
      const topRuler = document.getElementById('ruler-top');
      const leftRuler = document.getElementById('ruler-left');
      if(!topRuler || !leftRuler) return;
      topRuler.innerHTML = ''; leftRuler.innerHTML = '';

      const pxPerUnitX = vW / pW; 
      const pxPerUnitY = vH / pH;

      let interval = 1;
      if (pW > 200) interval = 10;
      if (pW > 1000) interval = 50;

      for(let i=0; i <= pW; i += interval) {
          let pos = i * pxPerUnitX;
          let tick = document.createElement('div');
          tick.className = 'ruler-tick';
          tick.style.left = pos + 'px';
          tick.style.bottom = '0';
          tick.style.width = '1px';
          tick.style.height = (i % (interval*5) === 0) ? '100%' : '30%';
          topRuler.appendChild(tick);

          if(i % (interval*5) === 0) {
              let label = document.createElement('div');
              label.className = 'ruler-label';
              label.innerText = i;
              label.style.left = (pos + 2) + 'px';
              label.style.top = '0';
              topRuler.appendChild(label);
          }
      }

      for(let i=0; i <= pH; i += interval) {
          let pos = i * pxPerUnitY;
          let tick = document.createElement('div');
          tick.className = 'ruler-tick';
          tick.style.top = pos + 'px';
          tick.style.right = '0';
          tick.style.height = '1px';
          tick.style.width = (i % (interval*5) === 0) ? '100%' : '30%';
          leftRuler.appendChild(tick);

          if(i % (interval*5) === 0 && i !== 0) {
              let label = document.createElement('div');
              label.className = 'ruler-label';
              label.innerText = i;
              label.style.top = (pos - 12) + 'px';
              label.style.left = '2px';
              label.style.transform = 'rotate(-90deg)';
              leftRuler.appendChild(label);
          }
      }
  }


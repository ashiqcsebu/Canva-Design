  function generateOffscreenImages(json, bgUrl, callback) {
    var tempCanvas = new fabric.StaticCanvas(null, { width: CANVAS_W, height: CANVAS_H });
    
    var doRender = function() {
      tempCanvas.backgroundImage = null;
      tempCanvas.backgroundColor = null;
      tempCanvas.renderAll();
      
      var transparentDataUrl = tempCanvas.toDataURL({ format: 'png', multiplier: 3.5 });
      var svgString = tempCanvas.toSVG();
      var svgBase64 = btoa(unescape(encodeURIComponent(svgString)));
      var svgDataUrl = 'data:image/svg+xml;base64,' + svgBase64;

      if (bgUrl && bgUrl.indexOf('no-image') === -1) {
        var finalUrl = bgUrl;
        if(bgUrl.indexOf('//') === 0) finalUrl = 'https:' + bgUrl;
        
        fabric.Image.fromURL(finalUrl, function(img) {
          if (img) {
            var scaleFactor = Math.min(CANVAS_W / img.width, CANVAS_H / img.height);
            tempCanvas.setBackgroundImage(img, function() {
              tempCanvas.renderAll();
              var bgDataUrl = tempCanvas.toDataURL({ format: 'png', multiplier: 1.5 });
              
              callback({ 
                transparent: transparentDataUrl, 
                withBg: bgDataUrl,
                vectorSvg: svgDataUrl
              });
            }, { originX: 'center', originY: 'center', left: CANVAS_W/2, top: CANVAS_H/2, crossOrigin: 'anonymous' });
          } else {
            callback({ transparent: transparentDataUrl, withBg: transparentDataUrl, vectorSvg: svgDataUrl });
          }
        }, { crossOrigin: 'anonymous' });
      } else {
        callback({ transparent: transparentDataUrl, withBg: transparentDataUrl, vectorSvg: svgDataUrl });
      }
    };

    if (json) {
      tempCanvas.loadFromJSON(json, function() {
        doRender();
      });
    } else {
      doRender();
    }
  }

  function dataURLtoFile(dataurl, filename) {
    var arr   = dataurl.split(',');
    var mimeMatch = arr[0].match(/:(.*?);/);
    var mime  = mimeMatch ? mimeMatch[1] : 'image/png';
    
    var bstr  = atob(arr[arr.length - 1]);
    var n     = bstr.length;
    var u8arr = new Uint8Array(n);
    while (n--) { u8arr[n] = bstr.charCodeAt(n); }
    return new File([u8arr], filename, { type: mime });
  }


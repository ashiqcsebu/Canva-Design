  /* ─── Background image ───────────────────────────────── */
  function setProductBackground(imageUrl) {
    if (!imageUrl) return;
    if (imageUrl.charAt(0) === '/' && imageUrl.charAt(1) === '/') imageUrl = 'https:' + imageUrl;
    fabric.Image.fromURL(imageUrl, function(img) {
      if (!img) return;
      var scaleFactor = Math.min(CANVAS_W / img.width, CANVAS_H / img.height);
      canvas.setBackgroundImage(img, canvas.renderAll.bind(canvas), {
        originX:     'center',
        originY:     'center',
        left:        CANVAS_W / 2,
        top:         CANVAS_H / 2,
        scaleX:      scaleFactor,
        scaleY:      scaleFactor,
        crossOrigin: 'anonymous'
      });
    }, { crossOrigin: 'anonymous' });
  }

  /* ─── VERY SIMPLE IMAGE MATCHING LOGIC ──────────────────────── */
  function getImageUrlForVariantAndView(colorName, viewName) {
    if (!viewName) return null;
    var targetColor = colorName ? colorName.toLowerCase().trim() : "";
    var targetView = viewName ? viewName.toLowerCase().trim() : "";
    
    function cleanAndSplit(str) {
       if (!str) return [];
       return str.toLowerCase().replace(/[^a-z0-9]/g, ' ').split(/\s+/).filter(Boolean);
    }

    var colorWords = cleanAndSplit(targetColor);
    var viewWords = cleanAndSplit(targetView);
    var looseMatchUrl = null; 

    for (var i = 0; i < productMedia.length; i++) {
      var altText = productMedia[i].alt;
      if (altText && typeof altText === 'string') {
        var cleanAltText = altText.toLowerCase();

        var hasColor = true;
        if (colorWords.length > 0) {
            hasColor = colorWords.every(function(word) {
                return cleanAltText.includes(word);
            });
        }

        var hasView = true;
        if (viewWords.length > 0) {
            hasView = viewWords.every(function(word) {
                return cleanAltText.includes(word);
            });
        }
        
        if (hasColor && hasView) return productMedia[i].url;

        if (!hasColor && hasView && !looseMatchUrl) {
           looseMatchUrl = productMedia[i].url;
        }
      }
    }
    
    if (looseMatchUrl) return looseMatchUrl;
    return null; 
  }

  /* ─── Subtotal & Quantity Logic ──────────────────────── */
  function changeQty(delta) {
    var input = document.getElementById('quantity');
    var val = parseInt(input.value, 10) || 1;
    val += delta;
    if (val < 1) val = 1;
    if (val > 99) val = 99;
    input.value = val;
    var qtyUi = document.getElementById('qty-multiplier-ui');
    if(qtyUi) qtyUi.innerText = val;
    updateSubtotal();
  }
  window.changeQty = changeQty;

  function updateSubtotal() {
    var qty = parseInt(document.getElementById('quantity').value, 10) || 1;
    var baseTotal = currentVariantPrice * qty;
    var addonsTotal = 0;
    var addonCount = 0;
    
    document.querySelectorAll('.addon-checkbox:checked').forEach(function(cb) {
      addonsTotal += parseInt(cb.getAttribute('data-price') || '0', 10);
      addonCount++;
    });

    if (isExpressDelivery && expressFeeCents > 0) { 
      addonsTotal += expressFeeCents; 
      addonCount++; 
    }

    var finalTotal = baseTotal + addonsTotal;
    
    document.getElementById('summary-base-price').innerHTML = formatMoney(baseTotal);
    document.getElementById('addon-label').innerText = 'Extras (' + addonCount + ')';
    document.getElementById('summary-addon-price').innerHTML = '+' + formatMoney(addonsTotal);
    document.getElementById('subtotal-display').innerHTML = formatMoney(finalTotal);
  }
  window.updateSubtotal = updateSubtotal;

  /* ─── LINKED OPTIONS STATE MANAGEMENT ────────────────── */
  var currentSelectedOptions = [];
  
  function initVariantState() {
    document.querySelectorAll('.variant-option-group').forEach(function(group, index) {
      var activeBtn = group.querySelector('.variant-btn.active');
      var activeSelect = group.querySelector('.variant-select');
      
      if (activeBtn) {
        currentSelectedOptions[index] = activeBtn.getAttribute('data-value');
      } else if (activeSelect) {
        currentSelectedOptions[index] = activeSelect.value;
      }
    });
  }

  function handleVariantClick(e) {
    var btn = e.currentTarget;
    var optIndex = parseInt(btn.getAttribute('data-option-index'), 10);
    var val = btn.getAttribute('data-value');

    currentSelectedOptions[optIndex] = val;

    var group = btn.closest('.option-values');
    group.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    findAndUpdateVariant();
  }
  
  function handleVariantChange(e) {
    var select = e.currentTarget;
    var optIndex = parseInt(select.getAttribute('data-option-index'), 10);
    var val = select.value;

    currentSelectedOptions[optIndex] = val;
    findAndUpdateVariant();
  }

  function findAndUpdateVariant() {
    if (productVariants.length === 0) return;

    var matchedVariant = productVariants.find(function(v) {
      return v.options.every(function(opt, i) { return opt === currentSelectedOptions[i]; });
    });

    if (!matchedVariant) {
      matchedVariant = productVariants.find(function(v) {
        return v.options[0] === currentSelectedOptions[0] && v.available; 
      });
      
      if (matchedVariant) {
        currentSelectedOptions = [...matchedVariant.options];
        updateVariantUIButtons();
      }
    }

    if (matchedVariant) {
      document.getElementById('selected-variant-id').value = matchedVariant.id;
      currentVariantPrice = matchedVariant.price;
      updateSubtotal();
      
      currentColorName = '';
      document.querySelectorAll('.variant-option-group').forEach(function(group, index) {
          var label = group.querySelector('.right-section-title').innerText.toLowerCase();
          if (label.includes('color') || label.includes('colour')) {
              currentColorName = currentSelectedOptions[index];
          }
      });

      var dynamicUrl = getImageUrlForVariantAndView(currentColorName, currentArea);

      if (!dynamicUrl && matchedVariant.featured_image && matchedVariant.featured_image.id) {
        var fId = matchedVariant.featured_image.id;
        var mediaIndex = productMedia.findIndex(function(m) { return m.id === fId; });
        if (mediaIndex !== -1) {
          dynamicUrl = productMedia[mediaIndex].url;
        }
      }

      currentBgUrl = dynamicUrl || fallbackImage;
      setProductBackground(currentBgUrl); 
    }
  }

  function updateVariantUIButtons() {
    document.querySelectorAll('.variant-btn').forEach(function(btn) {
      var idx = parseInt(btn.getAttribute('data-option-index'), 10);
      var val = btn.getAttribute('data-value');
      if (currentSelectedOptions[idx] === val) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
    
    document.querySelectorAll('.variant-select').forEach(function(select) {
      var idx = parseInt(select.getAttribute('data-option-index'), 10);
      if (select.value !== currentSelectedOptions[idx]) {
         select.value = currentSelectedOptions[idx];
      }
    });
  }

  document.querySelectorAll('.variant-btn').forEach(function(btn) {
    btn.addEventListener('click', handleVariantClick);
  });
  

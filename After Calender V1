  /* ─── DYNAMIC VIEW AVAILABILITY LOGIC ───────────────────────── */
  function updateViewAvailability() {
    var allowedViews = ['front'];
    var graphicCbs = document.querySelectorAll('.graphic-location-cb:checked');
    graphicCbs.forEach(function(cb) {
      var label = (cb.getAttribute('data-label') || '').toLowerCase();
      var labelWords = label.replace(/[^a-z0-9]/g, ' ').split(/\s+/).filter(Boolean);
      
      availableViews.forEach(function(view) {
        var v = view.toLowerCase();
        var viewWords = v.replace(/[^a-z0-9]/g, ' ').split(/\s+/).filter(Boolean);
        
        var hasOverlap = labelWords.some(function(word) {
           return viewWords.includes(word) && word.length > 2; 
        });

        if ((label.indexOf(v) !== -1 || v.indexOf(label) !== -1 || hasOverlap) && !allowedViews.includes(view)) {
          allowedViews.push(view);
        }
      });
    });

    var switched = false;
    availableViews.forEach(function(view) {
      if (view === 'front') return;

      var safeId = view.replace(/\s+/g, '-');
      var btn = document.getElementById('btn-view-' + safeId);
      
      if (btn) {
        if (allowedViews.includes(view)) {
          btn.classList.remove('locked-view');
          btn.removeAttribute('data-tooltip');
        } else {
          btn.classList.add('locked-view');
          btn.setAttribute('data-tooltip', 'Pick Graphic Location to View');
          
          if (currentArea === view) {
            switched = true;
          }
        }
      }
    });
    
    if (switched) {
      showToast('View locked. Switched to Front view.', 'error');
      switchView('front');
    }
  }
  window.updateViewAvailability = updateViewAvailability;


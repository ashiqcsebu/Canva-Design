<script>
(function() {
  'use strict';

  var isExpressDelivery = false;
  var expressFeeCents = parseInt(document.getElementById('express-fee-cents').value || '0', 10);
  var expressDaysLimit = parseInt(document.getElementById('express-days-limit').value || '0', 10);
  var expressVarId = document.getElementById('express-variant-id').value;

  function initializeDatePicker() {
    var dateInput = document.getElementById('delivery-date');
    if(dateInput){
      var today = new Date();
      var todayStr = today.toISOString().split('T')[0];
      dateInput.setAttribute('min', todayStr);
      
      if(expressDaysLimit > 0 && expressVarId) {
          document.getElementById('express-info-msg').style.display = 'block';
      }

      dateInput.addEventListener('change', function() {
        var selectedDate = new Date(this.value); var currentDay = new Date();
        currentDay.setHours(0,0,0,0); selectedDate.setHours(0,0,0,0);
        var diffDays = Math.ceil((selectedDate.getTime() - currentDay.getTime()) / (1000 * 60 * 60 * 24));
        var msgEl = document.getElementById('delivery-msg');

        if (diffDays < 0) {

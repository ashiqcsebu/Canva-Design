<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Alfa+Slab+One&family=Anton&family=Bangers&family=Bebas+Neue&family=Caveat&family=Cinzel&family=Courgette&family=Creepster&family=Dancing+Script&family=Fredoka+One&family=Lobster&family=Montserrat:wght@400;700&family=Oswald:wght@400;700&family=Pacifico&family=Permanent+Marker&family=Playfair+Display:wght@400;700&family=Righteous&family=Russo+One&family=Special+Elite&display=swap" rel="stylesheet">

{% style %}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}

  .app-studio-wrapper {
    --color-page-bg: {{ section.settings.app_bg_color }};
    --color-bg: {{ section.settings.bg_color }};
    --color-card: {{ section.settings.card_color }};
    --color-card-alt: {{ section.settings.card_alt_color }};
    --color-accent: {{ section.settings.accent_color }};
    --color-txt: {{ section.settings.text_color }};
    --color-muted: {{ section.settings.muted_color }};
    --color-border: {{ section.settings.border_color }};
    --color-canvas: {{ section.settings.canvas_bg_color }};
    --color-modal-bg: {{ section.settings.modal_bg_color }};
    --color-modal-icon: {{ section.settings.modal_icon_color }};
    
    --color-btn-bg: {{ section.settings.button_bg_color | default: '#000000' }};
    --color-btn-text: {{ section.settings.button_text_color | default: '#ffffff' }};
    --color-icon: {{ section.settings.icon_color | default: '#6b7280' }};
    --color-val-bg: {{ section.settings.val_bg_color | default: '#fee2e2' }};
    --color-val-text: {{ section.settings.val_text_color | default: '#dc2626' }};
    --color-highlight: #e8f0fe;
    --color-highlight-text: #1a73e8;

    background-color: var(--color-bg);
    min-height: 100vh;
    font-family: 'Inter', var(--font-body), sans-serif;
    display: flex;
    justify-content: center;
    margin: 0; padding: 0;
  }
  .app-studio-wrapper * { box-sizing: border-box; }
  
  /* Full screen modern container */
  .app-container { width: 100%; height: 100vh; background: var(--color-bg); display: flex; flex-direction: column; position: relative; }
  
  /* Topbar matching screenshot */
  .app-topbar { display: flex; align-items: center; justify-content: space-between; padding: 12px 25px; border-bottom: 1px solid var(--color-border); background: var(--color-bg); }
  .topbar-left { display: flex; align-items: center; gap: 12px; }
  .app-logo-icon { width: 36px; height: 36px; background: #111; color: #fff; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .topbar-title { font-size: 16px; font-weight: 800; color: var(--color-txt); margin: 0; text-transform: capitalize; letter-spacing: 0px; line-height: 1.2; }
  .topbar-subtitle { font-size: 11px; font-weight: 500; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.5px; }
  
  .topbar-center { display: flex; gap: 20px; align-items: center; }
  .tool-icon-btn { background: none; border: none; color: var(--color-icon); font-size: 16px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 6px; }
  .tool-icon-btn:hover { background: var(--color-card-alt); color: var(--color-txt); }
  .tool-icon-btn i { font-size: 16px; }
  .tool-divider { width: 1px; height: 20px; background: var(--color-border); }
  .zoom-indicator { font-size: 13px; font-weight: 600; color: var(--color-txt); }

  .topbar-right { display: flex; gap: 15px; align-items: center; }
  .topbar-btn { display: flex; align-items: center; gap: 8px; padding: 8px 16px; border: none; background: transparent; color: var(--color-txt); font-weight: 700; font-size: 14px; cursor: pointer; transition: 0.2s; }
  .topbar-btn i { font-size: 16px; }
  .topbar-btn:hover { background: var(--color-card-alt); border-radius: 8px; }
  .btn-close { width: 36px; height: 36px; border-radius: 8px; border: none; background: transparent; color: var(--color-txt); font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
  .btn-close:hover { background: var(--color-val-bg); color: var(--color-val-text); }
  
  /* 3-Column Workspace */
  .app-workspace { display: flex; flex: 1; overflow: hidden; }
  
  /* LEFT SIDEBAR (Tools) */
  .app-sidebar-left { width: 300px; background: var(--color-bg); border-right: 1px solid var(--color-border); display: flex; flex-direction: column; flex-shrink: 0; overflow-y: auto; }
  .app-sidebar-left::-webkit-scrollbar, .app-sidebar-right::-webkit-scrollbar { width: 6px; }
  .app-sidebar-left::-webkit-scrollbar-thumb, .app-sidebar-right::-webkit-scrollbar-thumb { background: #ddd; border-radius: 10px; }

  /* RIGHT SIDEBAR (Options & Checkout) */
  .app-sidebar-right { width: 360px; background: var(--color-bg); border-left: 1px solid var(--color-border); display: flex; flex-direction: column; flex-shrink: 0; overflow-y: auto; padding: 25px; }
  
  /* CENTER CANVAS */
  .app-canvas-zone { flex: 1; background: var(--color-bg); position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; }
  
  /* View Switcher Pills - Top Center of Canvas */
  .view-toggle-pill { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); display: flex; background: var(--color-bg); border: 1px solid var(--color-border); box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-radius: 30px; padding: 6px; gap: 5px; z-index: 10; }
  .view-btn { position: relative; display: flex; align-items: center; justify-content: center; padding: 8px 20px; border-radius: 20px; border: none; background: transparent; color: var(--color-muted); font-weight: 600; font-size: 13px; cursor: pointer; transition: 0.3s; text-transform: capitalize; }
  .view-btn.active { background: var(--color-card-alt); color: var(--color-txt); }
  .view-btn i { display: none; } /* Hidden for minimal look matching SS */
  .view-btn.locked-view {  cursor: not-allowed !important; background: transparent !important; color: var(--color-muted) !important; opacity: 0.5; }
  
  /* CSS Tooltip */
  .view-btn[data-tooltip]::after { content: attr(data-tooltip); position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%) translateY(10px); background-color: #333; color: #fff; padding: 8px 12px; border-radius: 6px; font-size: 12px; font-weight: 600; white-space: nowrap; z-index: 100; margin-bottom: 8px; opacity: 0; visibility: hidden; transition: all 0.2s ease; pointer-events: none; }
  .view-btn[data-tooltip]::before { content: ''; position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%) translateY(10px); border-width: 6px; border-style: solid; border-color: #333 transparent transparent transparent; z-index: 100; margin-bottom: -4px; opacity: 0; visibility: hidden; transition: all 0.2s ease; pointer-events: none; }
  .view-btn.locked-view:hover::after, .view-btn.locked-view:hover::before { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }

  /* Left Sidebar Accordion Cards */
  .tool-card { border: none; border-bottom: 1px solid var(--color-border); border-radius: 0; margin-bottom: 0; overflow: hidden; background: transparent; transition: 0.2s ease; }
  .tool-card-header { display: flex; align-items: center; padding: 18px 20px; cursor: pointer; background: transparent; transition: 0.2s; }
  .tool-card-header:hover { background: #fafafa; }
  .tool-icon-box { width: 24px; height: 24px; background: transparent; display: flex; align-items: center; justify-content: flex-start; margin-right: 12px; color: var(--color-icon); font-size: 16px; border: none; }
  .tool-titles { flex: 1; }
  .tool-main-title { font-weight: 600; font-size: 14px; color: var(--color-txt); margin: 0; }
  .tool-sub-title { display: none; } /* Hidden to match minimal UI */
  .tool-content { padding: 0 20px 20px 20px; display: none; background: transparent; border-top: none; }
  
  /* Active Tool State (Matches Add Text Blue highlight) */
  .tool-card.active .tool-content { display: block; }
  .tool-card.active { background: var(--color-highlight); border-bottom-color: var(--color-border); border-left: 3px solid var(--color-highlight-text); }
  .tool-card.active .tool-card-header { background: transparent; }
  .tool-card.active .tool-icon-box { color: var(--color-highlight-text); }
  .tool-card.active .tool-main-title { color: var(--color-highlight-text); }

  /* Right Sidebar Styles */
  .right-sidebar-section { margin-bottom: 30px; }
  .right-section-title { font-size: 12px; font-weight: 800; color: var(--color-txt); text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 15px 0; }
  
  /* Variants & Inputs */
  .prop-label { font-size: 13px; font-weight: 700; color: var(--color-txt); margin-bottom: 8px; display: block; }
  .variant-option-group { margin-bottom: 20px; }
  .option-values { display: flex; flex-wrap: wrap; gap: 8px; }
  .size-pill { padding: 10px 16px; border: 1px solid var(--color-border); border-radius: 6px; background: var(--color-bg); cursor: pointer; transition: 0.2s; font-weight: 600; font-size: 13px; color: var(--color-txt); }
  .size-pill:hover { border-color: var(--color-txt); }
  .size-pill.active { border-color: var(--color-txt); background: var(--color-txt); color: var(--color-bg); }
  .designer-select, .custom-input-modern { width: 100%; padding: 12px 14px; border: 1px solid var(--color-border); border-radius: 6px; font-size: 14px; background: var(--color-bg); color: var(--color-txt); transition: 0.2s; outline: none; }
  .designer-select:focus, .custom-input-modern:focus { border-color: var(--color-txt); }

  /* Order Summary in Right Sidebar */
  .order-summary-box { background: transparent; border: none; padding: 0; }
  .summary-row { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 13px; color: var(--color-muted); font-weight: 500; }
  .summary-row.total-row { margin-top: 15px; padding-top: 15px; border-top: 1px solid var(--color-border); font-size: 16px; font-weight: 800; color: var(--color-txt); align-items: center; }
  .price-amount { font-size: 18px; font-weight: 800; color: var(--color-txt); }
  
  /* Form components */
  .quantity-stepper-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .quantity-stepper { display: flex; align-items: center; border: 1px solid var(--color-border); border-radius: 6px; overflow: hidden; background: var(--color-bg); height: 40px; }
  .quantity-stepper button { background: none; border: none; padding: 0 15px; font-size: 18px; cursor: pointer; color: var(--color-txt); font-weight: bold; height: 100%; }
  .quantity-stepper button:hover { background: var(--color-card-alt); }
  .quantity-stepper input { width: 50px; text-align: center; border: none; font-weight: 600; background: transparent; color: var(--color-txt); font-size: 14px; pointer-events: none; }
  .quantity-stepper input::-webkit-outer-spin-button, .quantity-stepper input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .btn-submit { width: 100%; padding: 16px; background: var(--color-btn-bg); color: var(--color-btn-text); font-weight: 700; font-size: 15px; border: none; border-radius: 6px; cursor: pointer; transition: 0.2s; margin-top: 20px; }
  .btn-submit:hover { opacity: 0.9; }
  
  /* Add Text specific tweaks to match screenshot */
  .btn-add-element { padding: 12px; border: 1px solid var(--color-btn-bg); border-radius: 6px; background: var(--color-btn-bg); cursor: pointer; font-weight: 700; font-size: 14px; text-align: center; color: var(--color-btn-text); transition: 0.2s; width: 100%; }
  .btn-add-element:hover { opacity: 0.9; }
  .font-picker-btn { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 12px 14px; border: 1px solid var(--color-border); border-radius: 6px; background: var(--color-bg); font-size: 14px; cursor: pointer; color: var(--color-txt); margin-bottom: 15px; }

  /* Misc components */
  .upload-zone { border: 2px dashed var(--color-border); border-radius: 8px; padding: 25px; text-align: center; cursor: pointer; background: var(--color-bg); transition: 0.2s; }
  .upload-zone:hover { border-color: var(--color-txt); background: var(--color-card-alt); }
  .upload-zone i { font-size: 24px; color: var(--color-icon); margin-bottom: 10px; display: block; }
  input[type="range"] { width: 100%; accent-color: var(--color-txt); }

  .artwork-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 10px; }
  .artwork-item { width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 6px; border: 1px solid var(--color-border); cursor: pointer; transition: 0.2s; background: var(--color-bg); }
  .artwork-item:hover { border-color: var(--color-txt); }

  .layers-list { display: flex; flex-direction: column; gap: 8px; }
  .layer-item { display: flex; align-items: center; justify-content: space-between; padding: 12px; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 6px; cursor: pointer; transition: 0.2s; }
  .layer-item.active { border-color: var(--color-highlight-text); box-shadow: 0 0 0 1px var(--color-highlight-text); }
  .layer-info { font-size: 13px; font-weight: 500; color: var(--color-txt); flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; pointer-events: none; }
  .layer-actions { display: flex; gap: 5px; }
  .layer-btn { background: none; border: none; font-size: 14px; color: var(--color-icon); cursor: pointer; padding: 4px; border-radius: 4px; transition: 0.2s; }
  .layer-btn:hover { background: var(--color-card-alt); color: var(--color-txt); }
  
  .hidden { display: none !important; }
  
  /* Toast */
  .toast-container { position: fixed; bottom: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
  .toast { background: #333; color: #fff; padding: 12px 20px; border-radius: 6px; font-size: 14px; font-weight: 500; animation: slideIn 0.3s ease; }
  .toast.error { background: var(--color-val-bg); color: var(--color-val-text); }
  @keyframes slideIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

  /* Modals */
  .app-studio-modal-overlay { position: fixed; inset: 0; background: var(--color-modal-bg); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(4px); }
  .modal-content { background: var(--color-bg); padding: 30px; border-radius: 12px; width: 100%; max-width: 900px; position: relative; max-height: 95vh; overflow-y: auto; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
  .modal-close-btn { position: absolute; top: 15px; right: 15px; background: transparent; border: none; width: 36px; height: 36px; border-radius: 50%; font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--color-icon); transition: 0.2s; }
  .modal-close-btn:hover { color: var(--color-txt); background: var(--color-card-alt); }
  .modal-title { margin-top: 0; margin-bottom: 25px; font-weight: 700; font-size: 20px; color: var(--color-txt); text-align: center; }
  .modal-body { display: flex; flex-direction: column; gap: 20px; flex-wrap: wrap; }
  .modal-view-col { width: 100%; }
  .modal-view-label { font-weight: 700; margin-bottom: 10px; color: var(--color-txt); text-align: center; font-size: 14px; text-transform: capitalize; }
  .modal-img-box { border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; background: var(--color-canvas); padding: 15px; display: flex; justify-content: center; align-items: center; }
  .modal-img-box img { max-width: 100%; height: auto; border-radius: 4px; }
  @media (min-width: 768px) { .modal-body { flex-direction: row; align-items: flex-start; justify-content: center; } .modal-view-col { width: calc(50% - 10px); } }

  .font-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 12px; max-height: 60vh; overflow-y: auto; padding: 5px; }
  .font-card { border: 1px solid var(--color-border); border-radius: 6px; padding: 15px 5px; text-align: center; cursor: pointer; transition: 0.2s; background: var(--color-bg); display: flex; flex-direction: column; align-items: center; justify-content: center; height: 90px; }
  .font-card:hover { border-color: var(--color-txt); }
  .font-card.active { border-color: var(--color-txt); background: var(--color-txt); color: var(--color-bg); }
  .font-card.active .font-name-label { color: var(--color-bg); }
  .font-preview-text { font-size: 26px; margin-bottom: 5px; line-height: 1; }
  .font-name-label { font-size: 11px; color: var(--color-muted); font-family: 'Inter', sans-serif; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; }

  .inline-error-message { background-color: var(--color-val-bg); color: var(--color-val-text); font-size: 13px; font-weight: 600; text-align: center; margin-bottom: 15px; padding: 10px; border-radius: 6px; display: none; }
{% endstyle %}

<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<!-- Dynamic Express Delivery via Metafields -->
{% assign exp_variant = product.metafields.custom.express_delivery_variant.value %}
{% if exp_variant.first %}
  {% assign exp_variant = exp_variant.first %}
{% endif %}
{% assign exp_days = product.metafields.custom.express_delivery_days.value %}

<input type="hidden" id="express-variant-id" value="{{ exp_variant.id | default: '' }}">
<input type="hidden" id="express-fee-cents" value="{{ exp_variant.price | default: 0 }}">
<input type="hidden" id="express-days-limit" value="{{ exp_days | default: 0 }}">

<div class="app-studio-wrapper">
  <div id="toast-container" class="toast-container"></div>

  <div class="app-container">
    
    <!-- TOP BAR (Match visual style) -->
    <header class="app-topbar">
      <div class="topbar-left">
        <div class="app-logo-icon"><i class="fa-solid fa-layer-group"></i></div>
        <div>
          <h1 class="topbar-title">{{ product.title }}</h1>
          <span class="topbar-subtitle">{{ section.settings.subtitle }}</span>
        </div>
      </div>
      
      <div class="topbar-center">

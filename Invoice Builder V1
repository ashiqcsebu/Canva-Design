                           {/* Get current cell styles */}
                           {(() => {
                             const styleKey = activeTableCell.type === 'header' ? `h-${activeTableCell.c}` : `r${activeTableCell.r}-c${activeTableCell.c}`;
                             const currentStyles = (selectedElement.cellStyles && selectedElement.cellStyles[styleKey]) || {};

                             const handleStyleChange = (prop, value) => {
                               const newCellStyles = { ...selectedElement.cellStyles };
                               newCellStyles[styleKey] = { ...currentStyles, [prop]: value };
                               if(!value) delete newCellStyles[styleKey][prop];
                               updateSelectedElement({ cellStyles: newCellStyles });
                             };

                             return (
                               <div className="grid grid-cols-2 gap-3">
                                 <div>
                                   <label className="text-[10px] text-gray-700">Cell BG Color</label>
                                   <div className="flex gap-1 items-center">
                                      <input type="color" className="w-full h-[24px] rounded p-0 border border-gray-200" value={currentStyles.bg || '#ffffff'} onChange={(e) => handleStyleChange('bg', e.target.value)} onBlur={commitUpdate}/>
                                      <button onClick={() => {handleStyleChange('bg', ''); commitUpdate();}} className="text-[10px] text-red-500" title="Clear specific color">x</button>
                                   </div>
                                 </div>
                                 <div>
                                   <label className="text-[10px] text-gray-700">Cell Text Color</label>
                                   <div className="flex gap-1 items-center">
                                      <input type="color" className="w-full h-[24px] rounded p-0 border border-gray-200" value={currentStyles.color || '#000000'} onChange={(e) => handleStyleChange('color', e.target.value)} onBlur={commitUpdate}/>
                                      <button onClick={() => {handleStyleChange('color', ''); commitUpdate();}} className="text-[10px] text-red-500" title="Clear specific color">x</button>
                                   </div>
                                 </div>
                               </div>
                             );
                           })()}
                         </div>
                      )}
                   </div>
                 )}

                 {/* POSITION Indicator */}
                 <div className="mt-8 pt-4 border-t border-gray-100">
                   <label className="block text-[11px] font-bold text-gray-800 uppercase mb-2">Position & Dimensions</label>
                   <div className="flex gap-2 text-xs text-gray-600 bg-gray-100 px-3 py-2 rounded-lg font-mono">
                     X: {Math.round(selectedElement.x)}, Y: {Math.round(selectedElement.y)}
                     {selectedElement.width && `, W: ${Math.round(selectedElement.width)}`}
                   </div>
                   <p className="text-[10px] text-gray-400 mt-2 flex items-center gap-1">
                     <span className="bg-gray-200 px-1 rounded text-gray-600">Shift</span> + Drag to snap
                   </p>
                 </div>
               </div>
             )}
          </div>
        </div>

        {/* --- PREVIEW MODAL --- */}
        {showPreview && (
          <div className="fixed inset-0 z-50 flex flex-col bg-gray-900 bg-opacity-95 p-6">
             <div className="flex justify-between items-center mb-4 text-white">
                 <h2 className="font-bold flex items-center gap-2 text-xl"><IconCanvas/> Document Preview Mode</h2>
                 <button onClick={() => setShowPreview(false)} className="px-5 py-2 bg-white text-gray-900 rounded hover:bg-gray-200 font-bold transition">Close Preview</button>
             </div>
             
             {/* Readonly Render Container */}
             <div className="flex-1 overflow-auto flex justify-center items-start custom-scrollbar p-10 bg-black bg-opacity-40 rounded-xl shadow-inner">
                 <div className="bg-white shadow-2xl relative overflow-hidden shrink-0 border border-gray-400 pointer-events-none" style={canvasStyle}>
                     {/* Background Image */}
                     {canvasSettings.backgroundImage && (
                       <div className="absolute inset-0 pointer-events-none" style={{ backgroundImage: `url(${canvasSettings.backgroundImage})`, backgroundSize: 'cover', backgroundPosition: 'center', opacity: canvasSettings.backgroundOpacity / 100, zIndex: 0 }}></div>
                     )}
                     
                     {/* Watermark Layer */}
                     {canvasSettings.watermarkText && (
                       <div className="watermark-text" style={{ color: canvasSettings.watermarkColor, opacity: canvasSettings.watermarkOpacity / 100 }}>
                         {canvasSettings.watermarkText}
                       </div>
                     )}

                     {/* Elements Layer - Read Only Mode */}
                     {renderElements(true)}
                 </div>
             </div>
          </div>
        )}

      </div>
    );
  }

  const root = ReactDOM.createRoot(document.getElementById('shopify-invoice-builder-root'));
  root.render(<InvoiceBuilder />);
{% endraw %}
</script> 















  // Helper constants for Unit Conversions (96 DPI)
  const IN_TO_PX = 96;
  const CM_TO_PX = 37.795275591;
  const MM_TO_PX = 3.7795275591;

  // Convert raw value to Pixels
  const toPx = (val, unit) => {
    if(unit === 'in') return Math.round(val * IN_TO_PX);
    if(unit === 'cm') return Math.round(val * CM_TO_PX);
    if(unit === 'mm') return Math.round(val * MM_TO_PX);
    return val;
  };

  // Convert Pixels to a display string in a specific unit
  const fromPx = (px, unit) => {
    if(unit === 'in') return (px / IN_TO_PX).toFixed(2);
    if(unit === 'cm') return (px / CM_TO_PX).toFixed(2);
    if(unit === 'mm') return (px / MM_TO_PX).toFixed(1);
    return px;
  };

  // Bounds & Margin Calculator
  const getBounds = (settings) => {
      const activeFormat = canvasFormats.find(f => f.id === settings.format) || canvasFormats[0];
      const cW = settings.format === 'Custom' ? settings.customWidthPx : activeFormat.w;
      const cH = settings.format === 'Custom' ? settings.customHeightPx : activeFormat.h;
      const m = settings.margins || { top: 0, right: 0, bottom: 0, left: 0 };
      
      return {
          minX: m.left * CM_TO_PX,
          maxX: cW - (m.right * CM_TO_PX),
          minY: m.top * CM_TO_PX,
          maxY: cH - (m.bottom * CM_TO_PX),
          cW, cH
      };
  };

  const constrainCoord = (val, min, max, elSize) => {
      const size = elSize || 0;
      if (val < min) return min;
      if (val + size > max) return Math.max(min, max - size);
      return val;
  };


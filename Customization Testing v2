<script>
(function() {
  'use strict';

  /* ─── Utilities ─────────────────────────────────────── */
  function showToast(msg, type) {
    type = type || 'success';
    var container = document.getElementById('toast-container');
    if (!container) return;
    var toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.innerText = msg;
    container.appendChild(toast);
    setTimeout(function() { if (toast.parentNode) toast.parentNode.removeChild(toast); }, 3000);
  }

  /* ─── Money formatting ───────────────────────────────── */
  var moneyFormatEl = document.getElementById('shop-money-format');
  var defaultFormat = "$\x7B\x7Bamount\x7D\x7D";
  var moneyFormat = moneyFormatEl ? moneyFormatEl.value : defaultFormat;
  
  if (moneyFormat.indexOf('shop.money_format') !== -1 || moneyFormat.indexOf('\x7B\x7B') !== -1) {
    moneyFormat = defaultFormat; 
  }

  function formatMoney(cents) {
    if (typeof cents === 'string') { cents = cents.replace('.', ''); }
    cents = parseInt(cents, 10) || 0;
    var placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
    var match = (moneyFormat || '').match(placeholderRegex);
    if (!match) { return '$' + (cents / 100).toFixed(2); }

    function formatWithDelimiters(number, precision, thousands, decimal) {
      precision = precision !== undefined ? precision : 2;
      thousands = thousands || ',';
      decimal = decimal || '.';
      if (isNaN(number) || number == null) { return '0'; }
      number = (number / 100.0).toFixed(precision);
      var parts = number.split('.');
      var dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands);
      var centsPart = parts[1] ? (decimal + parts[1]) : '';
      return dollars + centsPart;
    }

    var value = '';
    switch (match[1]) {
      case 'amount': value = formatWithDelimiters(cents, 2); break;
      case 'amount_no_decimals': value = formatWithDelimiters(cents, 0); break;
      case 'amount_with_comma_separator': value = formatWithDelimiters(cents, 2, '.', ','); break;
      case 'amount_no_decimals_with_comma_separator': value = formatWithDelimiters(cents, 0, '.', ','); break;
      default: value = formatWithDelimiters(cents, 2);
    }
    return moneyFormat.replace(placeholderRegex, value);
  }

  /* ─── CurvedText (Fabric custom class) ──────────────── */
  fabric.CurvedText = fabric.util.createClass(fabric.Object, {
    type: 'curvedText',
    stateProperties: fabric.Object.prototype.stateProperties.concat([
      'text', 'radius', 'spacing', 'fontFamily', 'fontSize', 'fill', 'fontWeight', 'fontStyle', 'textAlign'
    ]),

    initialize: function(text, options) {
      options = options || {};
      this.text      = text || 'Curved Text';
      this.radius    = options.radius    !== undefined ? options.radius    : 120;
      this.spacing   = options.spacing   !== undefined ? options.spacing   : 5;
      this.fontFamily = options.fontFamily || 'Arial';
      this.fontSize  = options.fontSize  || 24;
      this.fontWeight = options.fontWeight || 'normal';
      this.fontStyle  = options.fontStyle  || 'normal';
      this.textAlign  = options.textAlign  || 'center';
      this.fill      = options.fill      || '#121212';
      this.callSuper('initialize', options);
      this._calcBounds();
    },

    _getFontString: function() {
      return (this.fontStyle || 'normal') + ' ' + (this.fontWeight || 'normal') + ' ' + this.fontSize + 'px ' + this.fontFamily;
    },

    _calcBounds: function() {
      var c = document.createElement('canvas').getContext('2d');
      c.font = this._getFontString();
      var chars = this.text ? this.text.split('') : [];
      var tw = 0;
      var self = this;
      chars.forEach(function(ch) { tw += c.measureText(ch).width + self.spacing; });
      tw = Math.max(1, tw - this.spacing);
      var absRadius  = Math.max(1, Math.abs(this.radius));
      var totalAngle = tw / absRadius;
      var halfAngle  = totalAngle / 2;
      var r          = absRadius;
      var top        = -r - this.fontSize * 0.6;
      var left       = -Math.cos(halfAngle) * r - this.fontSize * 0.5;
      var right      =  Math.cos(halfAngle) * r + this.fontSize * 0.5;
      var bottom     =  Math.sin(halfAngle) * r + this.fontSize * 0.6;
      this.set({
        width:  Math.max(1, Math.abs(left) + Math.abs(right)),
        height: Math.max(1, Math.abs(top)  + Math.abs(bottom))
      });
    },

    _render: function(ctx) {
      if (!this.text || !this.text.length) return;
      var chars = this.text.split('');
      ctx.font = this._getFontString();
      var self = this;
      var charWidths = [];
      var tw = 0;
      chars.forEach(function(ch) {
        var w = ctx.measureText(ch).width;
        charWidths.push(w);
        tw += w + self.spacing;
      });
      tw = Math.max(1, tw - this.spacing);
      var isReverse  = this.radius < 0;
      var r          = Math.max(1, Math.abs(this.radius));
      var totalAngle = tw / r;
      var startAngle = isReverse
        ? (Math.PI / 2 + totalAngle / 2)
        : (-Math.PI / 2 - totalAngle / 2);
      var curAngle = startAngle;
      for (var i = 0; i < chars.length; i++) {
        var charAngle = charWidths[i] / r;
        var midAngle  = isReverse ? (curAngle - charAngle / 2) : (curAngle + charAngle / 2);
        var x = Math.cos(midAngle) * r;
        var y = Math.sin(midAngle) * r;
        ctx.save();
        ctx.translate(x, y);
        ctx.rotate(isReverse ? midAngle - Math.PI / 2 : midAngle + Math.PI / 2);
        ctx.font = this._getFontString();
        ctx.fillStyle = this.fill;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(chars[i], 0, 0);
        ctx.restore();
        curAngle = isReverse
          ? (curAngle - charAngle - this.spacing / r)
          : (curAngle + charAngle + this.spacing / r);
      }
    },

    toObject: function() {
      return fabric.util.object.extend(this.callSuper('toObject'), {
        text: this.text,
        radius: this.radius,
        spacing: this.spacing,
        fontFamily: this.fontFamily,
        fontSize: this.fontSize,
        fontWeight: this.fontWeight,
        fontStyle: this.fontStyle,
        textAlign: this.textAlign,
        fill: this.fill
      });
    }
  });

  fabric.CurvedText.fromObject = function(object, callback) {
    var instance = new fabric.CurvedText(object.text, object);
    if (typeof callback === 'function') { callback(instance); }
    return instance;
  };

  /* ─── Canvas setup & Dynamic Views ───────────────────────────────────── */
  var CANVAS_W   = 600;
  var CANVAS_H   = 700;
  var PRINTABLE  = { left: 175, top: 160, width: 250, height: 300 };
  
  var CUSTOM_PROPS = ['id', 'text', 'radius', 'spacing', 'fontFamily', 'fontSize', 'fontWeight', 'fontStyle', 'textAlign', 'fill', 'opacity', 'angle', 'filters'];

  var fallbackImage = "{{ section.settings.fallback_image | image_url: width: 600 }}";
  if (!fallbackImage || fallbackImage.indexOf('no-image') !== -1) fallbackImage = '';

  var productMedia = [];
  try {
    var mediaJsonEl = document.getElementById('product-media-json');
    var mediaStr = mediaJsonEl ? mediaJsonEl.innerHTML.trim() : '';
    if (mediaStr && !mediaStr.includes('\x7B%')) {
      productMedia = JSON.parse(mediaStr);
    }
  } catch(e) {
    productMedia = [];
  }

  var availableViews = [];
  document.querySelectorAll('.view-btn').forEach(function(btn) {
      availableViews.push(btn.getAttribute('data-view-name').toLowerCase());
  });

  var currentArea       = availableViews.length > 0 ? availableViews[0] : 'front';
  var currentColorName  = '';
  var currentBgUrl      = fallbackImage;
  
  var areaStates        = {};
  var historyData       = [];
  var historyIdx        = -1;
  var isRestoringState  = false;
  var textCounter       = 0;

  var APPAREL_FONTS = [
    'Arial', 'Montserrat', 'Oswald', 'Bebas Neue', 'Lobster', 'Pacifico',
    'Anton', 'Righteous', 'Permanent Marker', 'Caveat', 'Russo One',
    'Bangers', 'Fredoka One', 'Alfa Slab One', 'Playfair Display',
    'Cinzel', 'Dancing Script', 'Courgette', 'Creepster', 'Special Elite'
  ];
  var currentFontTarget = 'normal';

  var currentVariantPriceEl = document.getElementById('current-variant-price');
  var currentVariantPrice = 0;
  if (currentVariantPriceEl && !currentVariantPriceEl.value.includes('\x7B\x7B')) {
    currentVariantPrice = parseInt(currentVariantPriceEl.value, 10) || 0;
  }

  var productJsonEl  = document.getElementById('ProductJson-{{ section.id }}');
  var productVariants = [];
  try { 
    var pStr = productJsonEl ? productJsonEl.innerHTML.trim() : '';
    if (pStr && !pStr.includes('\x7B\x7B')) {
      productVariants = JSON.parse(pStr); 
    }
  } catch(e) { productVariants = []; }

  var canvas = new fabric.Canvas('design-canvas', {
    width: CANVAS_W,
    height: CANVAS_H,
    selection: true,
    preserveObjectStacking: true
  });

  /* ─── Layers Panel Logic ─────────────────────────────── */
  function updateLayersPanel() {
    var list = document.getElementById('layers-list');
    if (!list) return;
    list.innerHTML = '';
    
    var objects = canvas.getObjects();
    if (objects.length === 0) {
      list.innerHTML = '<p style="font-size:12px; color:var(--color-muted); text-align:center; padding:10px;">No elements added.</p>';
      return;
    }
    
    for (var i = objects.length - 1; i >= 0; i--) {
      var obj = objects[i];
      var div = document.createElement('div');
      var isActive = (canvas.getActiveObject() === obj) ? 'active' : '';
      div.className = 'layer-item ' + isActive;
      
      div.onclick = (function(o) {
        return function() {
          canvas.setActiveObject(o);
          canvas.renderAll();
          updateLayersPanel();
        };
      })(obj);

      var label = obj.type;
      var icon = '<i class="fa-solid fa-shapes"></i>';
      if (obj.type === 'i-text') { label = 'Text: ' + (obj.text.substring(0, 10) || '...'); icon = '<i class="fa-solid fa-font"></i>'; }
      if (obj.type === 'curvedText') { label = 'Curved: ' + (obj.text.substring(0, 10) || '...'); icon = '<i class="fa-solid fa-text-height"></i>'; }
      if (obj.type === 'image') { label = 'Uploaded Image'; icon = '<i class="fa-regular fa-image"></i>'; }

      div.innerHTML = 

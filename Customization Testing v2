                    <div class="grid grid-cols-2 gap-2">
                        <button onclick="moveLayer('up')" class="py-1.5 text-xs bg-gray-100 hover:bg-gray-200 rounded border border-gray-300 flex items-center justify-center gap-1">
                            <i class="fa-solid fa-arrow-up"></i> Forward
                        </button>
                        <button onclick="moveLayer('down')" class="py-1.5 text-xs bg-gray-100 hover:bg-gray-200 rounded border border-gray-300 flex items-center justify-center gap-1">
                            <i class="fa-solid fa-arrow-down"></i> Backward
                        </button>
                    </div>
                </div>

                <!-- Delete -->
                <div class="pt-6 border-t border-gray-100">
                    <button onclick="deleteSelectedObject()" class="w-full py-2 text-sm text-red-600 hover:bg-red-50 rounded border border-red-200 flex justify-center items-center gap-2 transition">
                        <i class="fa-solid fa-trash"></i> Delete Layer
                    </button>
                </div>
            </div>
        </aside>

    </div>

    <!-- Hidden File Inputs -->
    <input type="file" id="image-upload" accept="image/*" class="hidden" onchange="handleImageUpload(event)">
    <input type="file" id="bg-upload" accept="image/*" class="hidden" onchange="handleBgUpload(event)">

    <script>
        // Ensure DOM is fully loaded before initializing Fabric.js in Shopify
        document.addEventListener('DOMContentLoaded', function() {
            
            const canvasWidth = {{ section.settings.default_width | default: 800 }};
            const canvasHeight = {{ section.settings.default_height | default: 400 }};
            
            // Initialize Canvas with unique ID
            window.designCanvas = new fabric.Canvas('design-canvas-{{ section.id }}', {
                width: canvasWidth,
                height: canvasHeight,
                backgroundColor: '#ffffff',
                preserveObjectStacking: true,
                selection: true
            });

            window.currentZoom = 1;
            window.gridLines = [];

            const propertiesPanel = document.getElementById('properties-panel');
            const colorPicker = document.getElementById('object-color');
            const opacitySlider = document.getElementById('object-opacity');
            const shadowToggle = document.getElementById('shadow-toggle');

            // Set up event listeners for selection
            window.designCanvas.on('selection:created', updateRightPanelUI);
            window.designCanvas.on('selection:updated', updateRightPanelUI);
            window.designCanvas.on('selection:cleared', () => propertiesPanel.classList.add('hidden'));

            // Smart Snapping Logic
            window.designCanvas.on('object:moving', function(options) {
                if(!document.getElementById('snap-toggle').checked) return;
                
                const obj = options.target;
                const snapDistance = 15;
                const centerX = window.designCanvas.width / window.currentZoom / 2;
                const centerY = window.designCanvas.height / window.currentZoom / 2;

                if (Math.abs(obj.left - centerX) < snapDistance) obj.set({ left: centerX });
                if (Math.abs(obj.top - centerY) < snapDistance) obj.set({ top: centerY });
            });

            function updateRightPanelUI() {
                propertiesPanel.classList.remove('hidden');
                const obj = window.designCanvas.getActiveObject();
                if(obj && obj.fill && typeof obj.fill === 'string' && obj.fill.startsWith('#')) {
                    colorPicker.value = obj.fill;
                }
                if(obj) {
                    const op = obj.opacity || 1;
                    opacitySlider.value = op;
                    document.getElementById('opacity-val').innerText = Math.round(op * 100) + '%';
                    shadowToggle.checked = obj.shadow ? true : false;
                }
            }
        });

        // Global functions accessible by inline onclick events
        function toggleBannerPanel() {
            const bannerPanel = document.getElementById('banner-panel');
            const dot = document.getElementById('banner-active-dot');
            if (bannerPanel.classList.contains('-translate-x-full')) {
                bannerPanel.classList.remove('-translate-x-full');
                bannerPanel.classList.add('translate-x-0');
                dot.classList.remove('hidden');
            } else {
                bannerPanel.classList.add('-translate-x-full');
                bannerPanel.classList.remove('translate-x-0');
                dot.classList.add('hidden');
            }
        }

        function updateCanvasSize() {
            const w = parseInt(document.getElementById('canvas-width').value);
            const h = parseInt(document.getElementById('canvas-height').value);
            if(w && h) {
                window.designCanvas.setWidth(w);
                window.designCanvas.setHeight(h);
                if(document.getElementById('grid-toggle').checked) drawGrid();
                window.designCanvas.renderAll();
                document.getElementById('preset-size').value = 'custom';
            }
        }

        function applyPresetSize() {
            const val = document.getElementById('preset-size').value;
            if(val === 'custom') return;
            const [w, h] = val.split('x');
            document.getElementById('canvas-width').value = w;
            document.getElementById('canvas-height').value = h;
            updateCanvasSize();
        }

        function changeZoom(amount) {
            window.currentZoom += amount;
            if(window.currentZoom < 0.5) window.currentZoom = 0.5;
            if(window.currentZoom > 3) window.currentZoom = 3;
            
            window.designCanvas.setZoom(window.currentZoom);
            window.designCanvas.setWidth(document.getElementById('canvas-width').value * window.currentZoom);
            window.designCanvas.setHeight(document.getElementById('canvas-height').value * window.currentZoom);
            document.getElementById('zoom-level').innerText = Math.round(window.currentZoom * 100) + '%';
        }

        function toggleGrid() {
            if (document.getElementById('grid-toggle').checked) drawGrid();
            else removeGrid();
        }

        function drawGrid() {
            removeGrid();
            const gridSize = 50;
            const width = window.designCanvas.width / window.currentZoom;
            const height = window.designCanvas.height / window.currentZoom;
            const gridColor = '#e5e7eb';

            for (let i = 0; i < (width / gridSize); i++) {
                let line = new fabric.Line([i * gridSize, 0, i * gridSize, height], { stroke: gridColor, selectable: false, evented: false, excludeFromExport: true });
                window.gridLines.push(line);
                window.designCanvas.add(line);
                line.sendToBack();
            }
            for (let i = 0; i < (height / gridSize); i++) {
                let line = new fabric.Line([0, i * gridSize, width, i * gridSize], { stroke: gridColor, selectable: false, evented: false, excludeFromExport: true });
                window.gridLines.push(line);
                window.designCanvas.add(line);
                line.sendToBack();
            }
        }

        function removeGrid() {
            window.gridLines.forEach(line => window.designCanvas.remove(line));
            window.gridLines = [];
        }

        function addText() {
            const text = new fabric.IText('Your Text Here', {
                left: (window.designCanvas.width / window.currentZoom) / 2,
                top: (window.designCanvas.height / window.currentZoom) / 2,
                originX: 'center', originY: 'center',
                fontFamily: 'Arial', fill: '#1e293b', fontSize: 40, fontWeight: 'bold'
            });
            window.designCanvas.add(text);
            window.designCanvas.setActiveObject(text);
        }

        function addRectangle() {
            const rect = new fabric.Rect({
                left: (window.designCanvas.width / window.currentZoom) / 2,
                top: (window.designCanvas.height / window.currentZoom) / 2,
                originX: 'center', originY: 'center',
                fill: '#3b82f6', width: 100, height: 100, rx: 5, ry: 5
            });
            window.designCanvas.add(rect);
            window.designCanvas.setActiveObject(rect);
        }

        function triggerImageUpload() { document.getElementById('image-upload').click(); }
        function triggerBgUpload() { document.getElementById('bg-upload').click(); }

        function handleImageUpload(e) {
            const file = e.target.files[0];
            if(!file) return;
            const reader = new FileReader();
            reader.onload = function(f) {
                fabric.Image.fromURL(f.target.result, function(img) {
                    img.scaleToWidth(200);
                    img.set({ left: 100, top: 100 });
                    window.designCanvas.add(img);
                    window.designCanvas.setActiveObject(img);
                });
            };
            reader.readAsDataURL(file);
            e.target.value = '';
        }

        function handleBgUpload(e) {
            const file = e.target.files[0];
            if(!file) return;
            const reader = new FileReader();
            reader.onload = function(f) {
                fabric.Image.fromURL(f.target.result, function(img) {
                    const canvasW = document.getElementById('canvas-width').value;
                    const canvasH = document.getElementById('canvas-height').value;
                    const scale = Math.max(canvasW / img.width, canvasH / img.height);
                    
                    img.set({
                        originX: 'center', originY: 'center',
                        left: canvasW / 2, top: canvasH / 2,
                        scaleX: scale, scaleY: scale
                    });
                    window.designCanvas.setBackgroundImage(img, window.designCanvas.renderAll.bind(window.designCanvas));
                });
            };
            reader.readAsDataURL(file);
        }

        function updateBackgroundColor(color) { window.designCanvas.setBackgroundColor(color, window.designCanvas.renderAll.bind(window.designCanvas)); }
        function clearBackground() {
            window.designCanvas.setBackgroundImage(null, window.designCanvas.renderAll.bind(window.designCanvas));
            window.designCanvas.setBackgroundColor('#ffffff', window.designCanvas.renderAll.bind(window.designCanvas));
            document.getElementById('bg-color').value = '#ffffff';
        }

        function moveLayer(direction) {
            const activeObj = window.designCanvas.getActiveObject();
            if(!activeObj) return;
            if(direction === 'up') window.designCanvas.bringForward(activeObj);
            if(direction === 'down') window.designCanvas.sendBackwards(activeObj);
            
            if(document.getElementById('grid-toggle').checked) {
                window.gridLines.forEach(line => line.sendToBack());
            }
            window.designCanvas.renderAll();
        }

        function toggleShadow(isON) {
            const activeObj = window.designCanvas.getActiveObject();
            if(!activeObj) return;
            if(isON) {
                activeObj.set('shadow', new fabric.Shadow({ color: 'rgba(0,0,0,0.3)', blur: 10, offsetX: 5, offsetY: 5 }));
            } else {
                activeObj.set('shadow', null);
            }
            window.designCanvas.renderAll();
        }

        function updateOpacity(val) {
            const activeObj = window.designCanvas.getActiveObject();
            if(!activeObj) return;
            activeObj.set('opacity', parseFloat(val));
            document.getElementById('opacity-val').innerText = Math.round(val * 100) + '%';
            window.designCanvas.renderAll();
        }

        function updateObjectProperty(prop, value) {
            const activeObject = window.designCanvas.getActiveObject();
            if (activeObject) {
                if(activeObject.type === 'i-text' && prop === 'fill') activeObject.set('fill', value);
                else activeObject.set(prop, value);
                window.designCanvas.renderAll();
            }
        }

        function deleteSelectedObject() {
            const activeObjects = window.designCanvas.getActiveObjects();
            if (activeObjects.length) {
                window.designCanvas.discardActiveObject();
                activeObjects.forEach(obj => window.designCanvas.remove(obj));
            }
            document.getElementById('properties-panel').classList.add('hidden');
        }

        function clearCanvas() {
            if(confirm("Clear everything?")) {
                window.designCanvas.clear();
                clearBackground();
                if(document.getElementById('grid-toggle').checked) drawGrid();
            }
        }

        function downloadDesign() {
            const wasGridOn = document.getElementById('grid-toggle').checked;
            if(wasGridOn) removeGrid();
            
            window.designCanvas.setZoom(1);
            window.designCanvas.setWidth(document.getElementById('canvas-width').value);
            window.designCanvas.setHeight(document.getElementById('canvas-height').value);
            
            const dataURL = window.designCanvas.toDataURL({ format: 'png', quality: 1, multiplier: 2 });
            const link = document.createElement('a');
            link.href = dataURL;
            link.download = 'custom-banner.png';
            link.click();

            if(wasGridOn) drawGrid();
            changeZoom(0);
        }
    </script>
</div>


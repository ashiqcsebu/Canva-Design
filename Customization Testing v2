  /* ─── LINKED OPTIONS STATE MANAGEMENT ────────────────── */
  var currentSelectedOptions = [];
  
  function initVariantState() {
    document.querySelectorAll('.variant-option-group').forEach(function(group, index) {
      var activeBtn = group.querySelector('.variant-btn.active');
      if (activeBtn) {
        currentSelectedOptions[index] = activeBtn.getAttribute('data-value');
      }
    });
  }

  function handleVariantClick(e) {
    var btn = e.currentTarget;
    var optIndex = parseInt(btn.getAttribute('data-option-index'), 10);
    var val = btn.getAttribute('data-value');

    currentSelectedOptions[optIndex] = val;

    var group = btn.closest('.option-values');
    group.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    findAndUpdateVariant();
  }

  function findAndUpdateVariant() {
    if (productVariants.length === 0) return;

    var matchedVariant = productVariants.find(function(v) {
      return v.options.every(function(opt, i) { return opt === currentSelectedOptions[i]; });
    });

    if (!matchedVariant) {
      matchedVariant = productVariants.find(function(v) {
        return v.options[0] === currentSelectedOptions[0] && v.available; 
      });
      if (matchedVariant) {
        currentSelectedOptions = [...matchedVariant.options];
        updateVariantUIButtons();
      }
    }

    if (matchedVariant) {
      document.getElementById('selected-variant-id').value = matchedVariant.id;
      currentVariantPrice = matchedVariant.price;
      updateSubtotal();
      
      currentColorName = '';
      document.querySelectorAll('.variant-option-group').forEach(function(group, index) {
          var label = group.querySelector('.prop-label').innerText.toLowerCase();
          if (label.includes('color') || label.includes('colour')) {
              currentColorName = currentSelectedOptions[index];
          }
      });

      var dynamicUrl = getImageUrlForVariantAndView(currentColorName, currentArea);

      if (!dynamicUrl && matchedVariant.featured_image && matchedVariant.featured_image.id) {
        var fId = matchedVariant.featured_image.id;
        var mediaIndex = productMedia.findIndex(function(m) { return m.id === fId; });
        if (mediaIndex !== -1) { dynamicUrl = productMedia[mediaIndex].url; }
      }

      currentBgUrl = dynamicUrl || fallbackImage;
      setProductBackground(currentBgUrl); 
    }
  }

  function updateVariantUIButtons() {
    document.querySelectorAll('.variant-btn').forEach(function(btn) {
      var idx = parseInt(btn.getAttribute('data-option-index'), 10);
      var val = btn.getAttribute('data-value');
      if (currentSelectedOptions[idx] === val) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }

  document.querySelectorAll('.variant-btn').forEach(function(btn) {
    btn.addEventListener('click', handleVariantClick);
  });

  /* ─── History ────────────────────────────────────────── */
  function saveHistory() {
    if (isRestoringState) return;
    historyData.splice(historyIdx + 1);
    historyData.push(JSON.stringify(canvas.toJSON(CUSTOM_PROPS)));
    historyIdx = historyData.length - 1;
    if (historyData.length > 40) { historyData.shift(); historyIdx--; }
  }

  function restoreFromHistory(json) {
    isRestoringState = true;
    canvas.loadFromJSON(json, function() {
      canvas.renderAll();
      isRestoringState = false;
      updatePropsPanel();
      updateLayersPanel();
    });
  }

  function undo() { if (historyIdx > 0) { historyIdx--; restoreFromHistory(historyData[historyIdx]); } }
  function redo() { if (historyIdx < historyData.length - 1) { historyIdx++; restoreFromHistory(historyData[historyIdx]); } }
  window.undo = undo;
  window.redo = redo;

  /* ─── View switching (Dynamic) ─────────────────────── */
  function saveAreaState() {
    areaStates[currentArea] = { json: JSON.stringify(canvas.toJSON(CUSTOM_PROPS)) };
  }

  function loadAreaState(area, newBgUrl) {
    currentBgUrl = newBgUrl;
    var state = areaStates[area];
    if (state && state.json) {
      restoreFromHistory(state.json);
      historyData = [state.json];
      historyIdx  = 0;
      setProductBackground(currentBgUrl);
    } else {
      canvas.getObjects().forEach(function(o) { canvas.remove(o); });
      canvas.discardActiveObject();
      setProductBackground(currentBgUrl);
      canvas.renderAll();
      historyData = [JSON.stringify(canvas.toJSON(CUSTOM_PROPS))];
      historyIdx  = 0;
      updatePropsPanel();
      updateLayersPanel();
    }
  }

  function switchView(dir) {
    saveAreaState();
    currentArea = dir.toLowerCase();
    
    var safeId = currentArea.replace(/\s+/g, '-');

    document.querySelectorAll('.view-btn').forEach(function(btn) {
      btn.classList.remove('active');
    });
    
    var activeBtn = document.getElementById('btn-view-' + safeId);
    if (activeBtn) {
      activeBtn.classList.add('active');
    }
    
    var dynamicUrl = getImageUrlForVariantAndView(currentColorName, currentArea);
    
    if (!dynamicUrl) {
       var vId = document.getElementById('selected-variant-id').value;
       var vMatch = productVariants.find(function(v) { return v.id == vId; });
       if (vMatch && vMatch.featured_image) {
           var mIdx = productMedia.findIndex(function(m) { return m.id === vMatch.featured_image.id; });
           if(mIdx !== -1) dynamicUrl = productMedia[mIdx].url;
       }
       if (!dynamicUrl && productMedia.length > 0) { dynamicUrl = productMedia[0].url; }
    }

    loadAreaState(currentArea, dynamicUrl || fallbackImage);
  }

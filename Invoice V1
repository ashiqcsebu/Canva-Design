{% schema %}
{
  "name": "Invoice Builder App",
  "settings": [],
  "presets": [
    {
      "name": "Invoice Builder App",
      "category": "Custom Apps"
    }
  ]
}
{% endschema %}

<!-- 
  We load TailwindCSS for styling and React/Babel from a CDN.
-->
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

<div id="shopify-invoice-builder-root"></div>

<script type="text/babel">
{% raw %}
  const { useState, useEffect, useRef } = React;

  // --- SVG Icons ---
  const IconType = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>;
  const IconSquare = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/></svg>;
  const IconTable = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="12" y1="3" x2="12" y2="21"/></svg>;
  const IconImage = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>;
  const IconDownload = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>;
  const IconUndo = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"/></svg>;
  const IconRedo = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 0 1 9-9 9 9 0 0 1 6 2.3l3 2.7"/></svg>;
  const IconCopy = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>;
  const IconTrash = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>;
  const IconSettings = () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>;
  const IconPlus = () => <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>;
  const IconMinus = () => <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>;
  const IconPen = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>;
  const IconLine = () => <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>;

  const documentTypes = [
    "INVOICE", "TAX INVOICE", "PROFORMA INVOICE", "RECEIPT", 
    "SALES RECEIPT", "CASH RECEIPT", "QUOTE", "ESTIMATE", 
    "CREDIT MEMO", "CREDIT NOTE", "PURCHASE ORDER", "DELIVERY NOTE"
  ];

  const templateClassic = [
    { id: '1', type: 'text', text: 'INVOICE', isMainTitle: true, x: 50, y: 50, fontSize: 36, fontWeight: 'bold', color: '#333333' },
    { id: '2', type: 'text', text: 'Company Name\n123 Business Rd.\nCity, Country', x: 50, y: 110, fontSize: 14, color: '#666666' },
    { id: '3', type: 'text', text: 'Bill To:\nCustomer Name\n456 Client St.', x: 50, y: 200, fontSize: 14, color: '#333333' },
    { id: '4', type: 'text', text: 'Doc #: INV-001\nDate: Oct 25, 2026', x: 550, y: 200, fontSize: 14, color: '#333333' },
    { id: '5', type: 'table', x: 50, y: 300, width: 650, 
      columns: ['Description', 'Qty', 'Price', 'Total'],
      rows: [
        ['Web Design Service', '1', '500', '500'],
        ['Hosting (1 Year)', '1', '150', '150']
      ]
    },
    { id: '6', type: 'text', text: 'Grand Total: $650.00', x: 550, y: 450, fontSize: 18, fontWeight: 'bold', color: '#000000' },
    { id: '7', type: 'line', width: 650, height: 2, x: 50, y: 280, color: '#e5e7eb' },
    { id: '8', type: 'signature', x: 50, y: 550, width: 200, text: 'Authorized Signature', color: '#333333' }
  ];

  const templateModern = [
    { id: '1', type: 'shape', width: 794, height: 150, x: 0, y: 0, color: '#2563eb' },
    { id: '2', type: 'text', text: 'TAX INVOICE', isMainTitle: true, x: 50, y: 50, fontSize: 40, fontWeight: 'bold', color: '#ffffff' },
    { id: '3', type: 'text', text: 'Doc #: 9982\nDate: Today', x: 600, y: 50, fontSize: 14, color: '#ffffff' },
    { id: '4', type: 'table', x: 50, y: 250, width: 694, 
      columns: ['Item', 'Quantity', 'Unit Price', 'Amount'],
      rows: [['Marketing Consultation', '5', '100', '500']]
    },
    { id: '5', type: 'text', text: 'Thank you for your business!', x: 50, y: 900, fontSize: 16, color: '#2563eb', fontWeight: 'bold' },
    { id: '6', type: 'signature', x: 544, y: 800, width: 200, text: 'Manager Signature', color: '#2563eb' }
  ];

  function InvoiceBuilder() {
    const [elements, setElements] = useState(templateClassic);
    const [selectedId, setSelectedId] = useState(null);
    const [editingId, setEditingId] = useState(null); 
    
    const currentMainTitleElement = elements.find(el => el.isMainTitle);
    const [currentDocType, setCurrentDocType] = useState(currentMainTitleElement ? currentMainTitleElement.text : "INVOICE");
    
    const [history, setHistory] = useState([templateClassic]);
    const [historyStep, setHistoryStep] = useState(0);
    
    const [dragStart, setDragStart] = useState(null); 
    const canvasRef = useRef(null);

    const saveHistory = (newElements) => {
      const newHistory = history.slice(0, historyStep + 1);
      newHistory.push(newElements);
      setHistory(newHistory);
      setHistoryStep(newHistory.length - 1);
    };

    const undo = () => {
      if (historyStep > 0) {
        setHistoryStep(historyStep - 1);
        setElements(history[historyStep - 1]);
        setSelectedId(null);
        setEditingId(null);
      }
    };

    const redo = () => {
      if (historyStep < history.length - 1) {
        setHistoryStep(historyStep + 1);
        setElements(history[historyStep + 1]);
        setSelectedId(null);
        setEditingId(null);
      }
    };

    const handleDocumentTypeChange = (e) => {
      const newType = e.target.value;
      setCurrentDocType(newType);
      
      const updatedElements = elements.map(el => {
        if (el.isMainTitle) {
          return { ...el, text: newType };
        }
        return el;
      });
      
      setElements(updatedElements);
      saveHistory(updatedElements);
    };

    const addElement = (type) => {
      const newElement = {
        id: Date.now().toString(),
        type: type,
        x: 100,
        y: 100,
      };

      if (type === 'text') {
        newElement.text = 'Double click to edit';
        newElement.fontSize = 16;
        newElement.color = '#000000';
      } else if (type === 'shape') {
        newElement.width = 200;
        newElement.height = 100;
        newElement.color = '#e5e7eb';
      } else if (type === 'line') {
        newElement.width = 400;
        newElement.height = 2;
        newElement.color = '#000000';
      } else if (type === 'signature') {
        newElement.width = 200;
        newElement.text = 'Authorized Signature';
        newElement.color = '#000000';
      } else if (type === 'table') {
        newElement.width = 600;
        newElement.columns = ['Item', 'Qty', 'Price', 'Total'];
        newElement.rows = [['Sample Item', '1', '10', '10']];
      } else if (type === 'image') {
        newElement.width = 150;
        newElement.height = 150;
        newElement.imageUrl = 'https://via.placeholder.com/150?text=Paste+Image+URL';
      }

      const updatedElements = [...elements, newElement];
      setElements(updatedElements);
      saveHistory(updatedElements);
      setSelectedId(newElement.id);
    };

    const duplicateElement = () => {
      if (!selectedId) return;
      const el = elements.find(e => e.id === selectedId);
      const newElement = { ...el, id: Date.now().toString(), x: el.x + 20, y: el.y + 20, isMainTitle: false };
      const updated = [...elements, newElement];
      setElements(updated);
      saveHistory(updated);
      setSelectedId(newElement.id);
    };

    const deleteElement = () => {
      if (!selectedId) return;
      const updated = elements.filter(e => e.id !== selectedId);
      setElements(updated);
      saveHistory(updated);
      setSelectedId(null);
      setEditingId(null);
    };

    const updateSelectedElement = (updates) => {
      if (!selectedId) return;
      const updatedElements = elements.map(el => 
        el.id === selectedId ? { ...el, ...updates } : el
      );
      setElements(updatedElements);
    };

    const commitUpdate = () => {
      saveHistory(elements);
    };

    const loadTemplate = (template) => {
      setElements(template);
      saveHistory(template);
      setSelectedId(null);
      setEditingId(null);
      
      const newMainTitle = template.find(el => el.isMainTitle);
      if(newMainTitle) setCurrentDocType(newMainTitle.text);
    };

    // --- Core Drag & Select Logic ---
    const handleMouseDown = (e, id) => {
      // EVENT BUBBLING FIX: This prevents the click from going to the background!
      e.stopPropagation(); 
      
      setSelectedId(id);
      
      if (editingId && editingId !== id) {
          setEditingId(null);
      }
      if (editingId === id) return; 

      const el = elements.find(item => item.id === id);
      if (!el) return;

      setDragStart({
        id: id,
        startX: e.clientX,
        startY: e.clientY,
        origX: el.x,
        origY: el.y
      });
    };

    const handleMouseMove = (e) => {
      if (!dragStart) return;
      
      let newX = dragStart.origX + (e.clientX - dragStart.startX);
      let newY = dragStart.origY + (e.clientY - dragStart.startY);

      if (e.shiftKey) {
        newX = Math.round(newX / 10) * 10;
        newY = Math.round(newY / 10) * 10;
      }

      setElements(prev => prev.map(el => 
        el.id === dragStart.id ? { ...el, x: newX, y: newY } : el
      ));
    };

    const handleMouseUp = () => {
      if (dragStart) {
        setDragStart(null);
        commitUpdate(); 
      }
    };

    const handleBackgroundMouseDown = (e) => {
      // Only deselect if clicking exactly on the grey background or canvas root wrapper
      if (e.target.id === 'canvas-wrapper' || e.target.id === 'invoice-canvas') {
        setSelectedId(null);
        setEditingId(null);
      }
    };

    const handlePrint = () => {
      setSelectedId(null);
      setEditingId(null);
      setTimeout(() => window.print(), 100);
    };

    const selectedElement = elements.find(e => e.id === selectedId);

    // ==========================================
    // 100% ROBUST 3-COLUMN LAYOUT (NO FLOATING MENUS)
    // ==========================================
    return (
      <div 
        className="flex h-screen w-full bg-gray-100 font-sans text-gray-800 overflow-hidden" 
        style={{minHeight: '800px'}}
      >
        <style>
          {`
            @media print {
              body * { visibility: hidden; }
              #invoice-canvas, #invoice-canvas * { visibility: visible; }
              #invoice-canvas { 
                position: absolute; 
                left: 0; 
                top: 0; 
                border: none !important;
                box-shadow: none !important;
              }
              .no-print { display: none !important; }
              .selected-border { outline: none !important; }
            }
            .content-editable-active {
                outline: 2px solid #3b82f6 !important;
                border-radius: 4px;
                padding: 2px;
                background-color: rgba(59, 130, 246, 0.05);
            }
            .custom-scrollbar::-webkit-scrollbar {
              width: 6px;
            }
            .custom-scrollbar::-webkit-scrollbar-thumb {
              background: #cbd5e1;
              border-radius: 10px;
            }
          `}
        </style>

        {/* ========================================== */}
        {/* COLUMN 1: LEFT SIDEBAR (TOOLS)             */}
        {/* ========================================== */}
        <div className="w-64 bg-white border-r border-gray-200 flex flex-col no-print z-30 shrink-0 h-full">
          <div className="p-4 border-b border-gray-200 shrink-0">
            <h1 className="text-lg font-bold flex items-center gap-2">
              <IconTable /> Doc Builder
            </h1>
            <p className="text-xs text-gray-500 mt-1">Design any document type</p>
          </div>

          <div className="p-4 flex-1 overflow-y-auto custom-scrollbar">
            {/* Document Type Selector */}
            <div className="mb-6 bg-blue-50 p-3 rounded-lg border border-blue-100">
               <label className="block text-xs font-bold text-blue-800 mb-1">Document Type</label>
               <select 
                 className="w-full text-sm border border-blue-200 rounded p-1.5 bg-white text-gray-700 focus:outline-blue-500"
                 value={currentDocType}
                 onChange={handleDocumentTypeChange}
               >
                 {documentTypes.map(type => (
                   <option key={type} value={type}>{type}</option>
                 ))}
               </select>
            </div>

            <h2 className="text-xs font-semibold text-gray-400 uppercase mb-3">Add Elements</h2>
            <div className="grid grid-cols-2 gap-2 mb-6">
              <button onClick={() => addElement('text')} className="flex flex-col items-center justify-center p-3 border border-gray-200 rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-600 transition-colors">
                <div className="mb-1 text-gray-500"><IconType /></div>
                <span className="text-xs font-medium">Text</span>
              </button>
              <button onClick={() => addElement('shape')} className="flex flex-col items-center justify-center p-3 border border-gray-200 rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-600 transition-colors">
                <div className="mb-1 text-gray-500"><IconSquare /></div>
                <span className="text-xs font-medium">Shape</span>
              </button>
              <button onClick={() => addElement('line')} className="flex flex-col items-center justify-center p-3 border border-gray-200 rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-600 transition-colors">
                <div className="mb-1 text-gray-500"><IconLine /></div>
                <span className="text-xs font-medium">Line</span>
              </button>
              <button onClick={() => addElement('table')} className="flex flex-col items-center justify-center p-3 border border-gray-200 rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-600 transition-colors">
                <div className="mb-1 text-gray-500"><IconTable /></div>
                <span className="text-xs font-medium">Table</span>
              </button>
              <button onClick={() => addElement('signature')} className="flex flex-col items-center justify-center p-3 border border-gray-200 rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-600 transition-colors">
                <div className="mb-1 text-gray-500"><IconPen /></div>
                <span className="text-xs font-medium">Signature</span>
              </button>
              <button onClick={() => addElement('image')} className="flex flex-col items-center justify-center p-3 border border-gray-200 rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-600 transition-colors">
                <div className="mb-1 text-gray-500"><IconImage /></div>
                <span className="text-xs font-medium">Image</span>
              </button>
            </div>

            <h2 className="text-xs font-semibold text-gray-400 uppercase mb-3">Templates</h2>
            <div className="space-y-2">
              <button onClick={() => loadTemplate(templateClassic)} className="w-full text-left p-3 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors font-medium text-gray-700">
                Classic Design
              </button>
              <button onClick={() => loadTemplate(templateModern)} className="w-full text-left p-3 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors font-medium text-gray-700">
                Blue Modern
              </button>
            </div>
          </div>

          <div className="p-4 border-t border-gray-200 shrink-0">
            <button onClick={handlePrint} className="w-full flex items-center justify-center gap-2 bg-blue-600 text-white py-2.5 px-4 rounded-lg hover:bg-blue-700 transition font-medium shadow-sm">
              <IconDownload /> Export PDF
            </button>
          </div>
        </div>

        {/* ========================================== */}
        {/* COLUMN 2: CENTER CANVAS WORKSPACE          */}
        {/* ========================================== */}
        <div 
          id="canvas-wrapper"
          className="flex-1 overflow-auto bg-gray-100 p-8 flex justify-center items-start relative h-full"
          onMouseMove={handleMouseMove} 
          onMouseUp={handleMouseUp}
          onMouseLeave={handleMouseUp}
          onMouseDown={handleBackgroundMouseDown} // Fixed Event Bubbling Deselection Bug
        >
          
          {/* Static Top Action Toolbar (No longer floating over properties) */}
          <div className="absolute top-6 left-1/2 -translate-x-1/2 flex gap-1 bg-white shadow-md p-1.5 rounded-xl border border-gray-200 no-print z-30">
            <button onClick={undo} disabled={historyStep === 0} className="p-2 hover:bg-gray-100 rounded-lg disabled:opacity-30 text-gray-700 transition-colors" title="Undo">
              <IconUndo />
            </button>
            <button onClick={redo} disabled={historyStep === history.length - 1} className="p-2 hover:bg-gray-100 rounded-lg disabled:opacity-30 text-gray-700 transition-colors" title="Redo">
              <IconRedo />
            </button>
            <div className="w-px bg-gray-200 mx-1 my-1"></div>
            <button onClick={duplicateElement} disabled={!selectedId} className="p-2 hover:bg-blue-50 rounded-lg disabled:opacity-30 text-blue-600 transition-colors" title="Duplicate">
              <IconCopy />
            </button>
            <button onClick={deleteElement} disabled={!selectedId} className="p-2 hover:bg-red-50 rounded-lg disabled:opacity-30 text-red-600 transition-colors" title="Delete">
              <IconTrash />
            </button>
          </div>

          {/* The Actual Canvas Document */}
          <div 
            id="invoice-canvas"
            ref={canvasRef}
            className="bg-white shadow-xl relative overflow-hidden shrink-0 border border-gray-200 mt-16 mb-16"
            style={{ width: '794px', height: '1123px' }}
          >
            {elements.map((el) => {
              const isSelected = selectedId === el.id;
              const isEditing = editingId === el.id;
              const isDraggingThis = dragStart && dragStart.id === el.id;

              return (
                <div
                  key={el.id}
                  onMouseDown={(e) => handleMouseDown(e, el.id)}
                  onClick={(e) => e.stopPropagation()} // Event Bubbling Fix
                  className={`absolute ${isEditing ? '' : 'cursor-move'} ${isSelected ? 'outline outline-2 outline-blue-500 selected-border z-20' : 'hover:outline hover:outline-1 hover:outline-gray-300 z-10'}`}
                  style={{
                    left: `${el.x}px`,
                    top: `${el.y}px`,
                    width: el.width ? `${el.width}px` : 'auto',
                    height: el.height ? `${el.height}px` : 'auto',
                    userSelect: isEditing ? 'auto' : 'none', 
                    pointerEvents: isDraggingThis ? 'none' : 'auto', 
                  }}
                >
                  {/* TEXT */}
                  {el.type === 'text' && (
                    <div 
                      contentEditable={isEditing}
                      suppressContentEditableWarning={true}
                      onDoubleClick={(e) => { 
                         e.stopPropagation(); 
                         setEditingId(el.id); 
                         setSelectedId(el.id);
                         setTimeout(() => e.target.focus(), 50); 
                      }}
                      onBlur={(e) => {
                         if (isEditing) {
                            setEditingId(null);
                            const newText = e.target.innerText;
                            const updated = elements.map(item => item.id === el.id ? { ...item, text: newText } : item);
                            setElements(updated);
                            saveHistory(updated);
                            if(el.isMainTitle) setCurrentDocType(newText);
                         }
                      }}
                      className={isEditing ? 'content-editable-active' : ''}
                      style={{ 
                        fontSize: `${el.fontSize}px`, 
                        color: el.color, 
                        fontWeight: el.fontWeight || 'normal', 
                        whiteSpace: 'pre-wrap', 
                        lineHeight: '1.2',
                        minWidth: '50px',
                        cursor: isEditing ? 'text' : 'move'
                      }}
                    >
                      {el.text}
                    </div>
                  )}

                  {/* SHAPE */}
                  {el.type === 'shape' && (
                    <div style={{ width: '100%', height: '100%', backgroundColor: el.color }}></div>
                  )}
                  
                  {/* LINE */}
                  {el.type === 'line' && (
                    <div style={{ width: '100%', height: `${el.height}px`, backgroundColor: el.color }}></div>
                  )}
                  
                  {/* SIGNATURE */}
                  {el.type === 'signature' && (
                    <div style={{ width: '100%', display: 'flex', flexDirection: 'column', alignItems: 'center' }}>
                       <div style={{ width: '100%', height: '2px', backgroundColor: el.color, marginBottom: '8px' }}></div>
                       <div style={{ color: el.color, fontSize: '14px', fontWeight: 'bold' }}>{el.text}</div>
                    </div>
                  )}

                  {/* IMAGE */}
                  {el.type === 'image' && (
                    <div style={{ width: '100%', height: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', backgroundColor: el.imageUrl ? 'transparent' : '#f3f4f6' }}>
                       {el.imageUrl ? (
                          <img src={el.imageUrl} alt="Invoice Element" draggable="false" style={{ width: '100%', height: '100%', objectFit: 'contain' }} />
                       ) : (
                          <span className="text-gray-400 text-xs text-center px-2">Image Placeholder</span>
                       )}
                    </div>
                  )}

                  {/* TABLE */}
                  {el.type === 'table' && (
                    <table className="w-full border-collapse bg-white">
                      <thead>
                        <tr className="bg-gray-50 border-b-2 border-gray-800">
                          {el.columns.map((col, i) => (
                            <th key={i} className="text-left p-2 text-sm font-bold text-gray-700">{col}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {el.rows.map((row, rowIndex) => (
                          <tr key={rowIndex} className="border-b border-gray-200">
                            {row.map((cell, cellIndex) => (
                              <td key={cellIndex} className="p-2 text-sm text-gray-600">{cell}</td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  )}
                </div>
              );
            })}
          </div>
        </div>

        {/* ========================================== */}
        {/* COLUMN 3: RIGHT SIDEBAR (PROPERTIES)       */}
        {/* ========================================== */}
        <div className="w-80 bg-white border-l border-gray-200 flex flex-col no-print z-30 shrink-0 h-full">
          <div className="p-4 border-b border-gray-200 shrink-0">
             <h2 className="text-sm font-bold flex items-center gap-2 text-gray-800">
               <IconSettings /> Edit Properties
             </h2>
          </div>
          
          <div className="p-5 flex-1 overflow-y-auto custom-scrollbar">
             {!selectedElement ? (
               /* PLACEHOLDER: Shows when no element is selected */
               <div className="flex flex-col items-center justify-center h-full text-gray-400 pb-20">
                  <IconSettings />
                  <p className="text-xs text-center mt-3 leading-relaxed px-4">
                    Click on any element in the canvas to edit its properties here.
                  </p>
               </div>
             ) : (
               /* PROPERTIES CONTROLS */
               <div className="pb-10">
                  {/* TEXT Properties */}
                  {selectedElement.type === 'text' && (
                    <div className="space-y-5">
                      <div className="p-3 bg-blue-50 border border-blue-100 rounded-lg text-xs text-blue-800 leading-relaxed flex gap-2 items-start">
                        <IconPen />
                        <span><strong>Double-click</strong> the text on the canvas to type directly!</span>
                      </div>
                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Font Size (px)</label>
                          <input type="number" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all"
                            value={selectedElement.fontSize || 14}
                            onChange={(e) => updateSelectedElement({ fontSize: Number(e.target.value) })}
                            onBlur={commitUpdate}
                          />
                        </div>
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Color</label>
                          <input type="color" className="w-full h-[38px] border border-gray-300 rounded-lg cursor-pointer p-0.5"
                            value={selectedElement.color || '#000000'}
                            onChange={(e) => updateSelectedElement({ color: e.target.value })}
                            onBlur={commitUpdate}
                          />
                        </div>
                      </div>
                      <div>
                        <label className="block text-xs font-semibold text-gray-600 mb-1.5">Font Weight</label>
                        <select 
                          className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all"
                          value={selectedElement.fontWeight || 'normal'}
                          onChange={(e) => { updateSelectedElement({ fontWeight: e.target.value }); commitUpdate(); }}
                        >
                          <option value="normal">Normal</option>
                          <option value="bold">Bold</option>
                        </select>
                      </div>
                    </div>
                  )}

                  {/* SHAPE & LINE Properties */}
                  {(selectedElement.type === 'shape' || selectedElement.type === 'line') && (
                    <div className="space-y-5">
                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Width (px)</label>
                          <input type="number" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none"
                            value={selectedElement.width}
                            onChange={(e) => updateSelectedElement({ width: Number(e.target.value) })}
                            onBlur={commitUpdate}
                          />
                        </div>
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Height (px)</label>
                          <input type="number" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none"
                            value={selectedElement.height}
                            onChange={(e) => updateSelectedElement({ height: Number(e.target.value) })}
                            onBlur={commitUpdate}
                          />
                        </div>
                      </div>
                      <div>
                        <label className="block text-xs font-semibold text-gray-600 mb-1.5">Color</label>
                        <input type="color" className="w-full h-[38px] border border-gray-300 rounded-lg cursor-pointer p-0.5"
                          value={selectedElement.color || '#e5e7eb'}
                          onChange={(e) => updateSelectedElement({ color: e.target.value })}
                          onBlur={commitUpdate}
                        />
                      </div>
                    </div>
                  )}

                  {/* SIGNATURE Properties */}
                  {selectedElement.type === 'signature' && (
                    <div className="space-y-5">
                      <div>
                        <label className="block text-xs font-semibold text-gray-600 mb-1.5">Signature Label</label>
                        <input type="text" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none"
                          value={selectedElement.text}
                          onChange={(e) => updateSelectedElement({ text: e.target.value })}
                          onBlur={commitUpdate}
                        />
                      </div>
                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Width (px)</label>
                          <input type="number" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none"
                            value={selectedElement.width}
                            onChange={(e) => updateSelectedElement({ width: Number(e.target.value) })}
                            onBlur={commitUpdate}
                          />
                        </div>
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Color</label>
                          <input type="color" className="w-full h-[38px] border border-gray-300 rounded-lg cursor-pointer p-0.5"
                            value={selectedElement.color || '#000000'}
                            onChange={(e) => updateSelectedElement({ color: e.target.value })}
                            onBlur={commitUpdate}
                          />
                        </div>
                      </div>
                    </div>
                  )}
                  
                  {/* IMAGE Properties */}
                  {selectedElement.type === 'image' && (
                    <div className="space-y-5">
                      <div>
                        <label className="block text-xs font-semibold text-gray-600 mb-1.5">Image URL</label>
                        <input type="text" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none"
                          placeholder="https://example.com/logo.png"
                          value={selectedElement.imageUrl || ''}
                          onChange={(e) => updateSelectedElement({ imageUrl: e.target.value })}
                          onBlur={commitUpdate}
                        />
                      </div>
                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Width (px)</label>
                          <input type="number" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none"
                            value={selectedElement.width}
                            onChange={(e) => updateSelectedElement({ width: Number(e.target.value) })}
                            onBlur={commitUpdate}
                          />
                        </div>
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Height (px)</label>
                          <input type="number" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none"
                            value={selectedElement.height}
                            onChange={(e) => updateSelectedElement({ height: Number(e.target.value) })}
                            onBlur={commitUpdate}
                          />
                        </div>
                      </div>
                    </div>
                  )}

                  {/* TABLE Properties */}
                  {selectedElement.type === 'table' && (
                    <div className="space-y-5">
                       <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-1.5">Table Width (px)</label>
                          <input type="number" className="w-full text-sm border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none"
                            value={selectedElement.width}
                            onChange={(e) => updateSelectedElement({ width: Number(e.target.value) })}
                            onBlur={commitUpdate}
                          />
                        </div>
                        
                        <div>
                          <label className="block text-xs font-semibold text-gray-600 mb-2">Edit Data Rows</label>
                          <div className="space-y-2">
                            {selectedElement.rows.map((row, rIndex) => (
                              <div key={`row-${rIndex}`} className="flex gap-1 items-center bg-gray-50 p-1 rounded-md border border-gray-200">
                                {row.map((cell, cIndex) => (
                                  <input 
                                    key={`cell-${rIndex}-${cIndex}`}
                                    type="text" 
                                    className="w-full text-xs border border-gray-300 rounded p-1.5 focus:border-blue-500 outline-none"
                                    value={cell}
                                    placeholder={`Col ${cIndex + 1}`}
                                    onChange={(e) => {
                                      const newRows = [...selectedElement.rows];
                                      newRows[rIndex][cIndex] = e.target.value;
                                      
                                      if (cIndex === 1 || cIndex === 2) {
                                         const qty = Number(newRows[rIndex][1]) || 0;
                                         const price = Number(newRows[rIndex][2]) || 0;
                                         newRows[rIndex][3] = (qty * price).toString();
                                      }
                                      
                                      updateSelectedElement({ rows: newRows });
                                    }}
                                    onBlur={commitUpdate}
                                  />
                                ))}
                                <button 
                                  onClick={() => {
                                     const newRows = selectedElement.rows.filter((_, i) => i !== rIndex);
                                     updateSelectedElement({ rows: newRows });
                                     commitUpdate();
                                  }}
                                  className="p-1.5 text-red-500 hover:bg-red-100 rounded-md transition-colors shrink-0"
                                  title="Delete Row"
                                >
                                  <IconMinus />
                                </button>
                              </div>
                            ))}
                          </div>
                          <button 
                            onClick={() => {
                              const newRow = Array(selectedElement.columns.length).fill('');
                              const newRows = [...selectedElement.rows, newRow];
                              updateSelectedElement({ rows: newRows });
                              commitUpdate();
                            }}
                            className="w-full mt-3 py-2 border border-dashed border-gray-400 text-gray-700 rounded-lg text-xs hover:bg-gray-50 hover:border-gray-500 flex justify-center items-center gap-1 font-medium transition-colors"
                          >
                            <IconPlus /> Add New Row
                          </button>
                        </div>
                    </div>
                  )}

                  {/* POSITION Indicator */}
                  <div className="mt-8 pt-4 border-t border-gray-100">
                    <label className="block text-xs font-semibold text-gray-500 mb-2">Element Position (X, Y)</label>
                    <div className="flex gap-2 text-xs text-gray-600 bg-gray-100 px-3 py-2 rounded-lg font-mono">
                      X: {Math.round(selectedElement.x)}, Y: {Math.round(selectedElement.y)}
                    </div>
                    <p className="text-[10px] text-gray-400 mt-2 flex items-center gap-1">
                      <span className="bg-gray-200 px-1 rounded text-gray-600">Shift</span> + Drag to snap to grid
                    </p>
                  </div>
               </div>
             )}
          </div>
        </div>

      </div>
    );
  }

  const root = ReactDOM.createRoot(document.getElementById('shopify-invoice-builder-root'));
  root.render(<InvoiceBuilder />);
{% endraw %}
</script>
